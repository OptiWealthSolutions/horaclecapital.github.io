---
import SEO from '../components/SEO.astro';
import FeedbackForm from '../components/FeedbackForm.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (path: string) => getRelativeLocaleUrl(lang, path);

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	articleDate?: string;
	activeNav?: 'home' | 'reports' | 'research' | 'about' | 'academy' | 'portfolio';
}

const { 
  title = "HORACLE CAPITAL | Analyse Macro & Finance Quantitative", 
  description = "Horacle Capital est une structure de recherche spécialisée dans l'analyse macroéconomique et la modélisation quantitative des marchés financiers.", 
  image = "https://horaclecapital.com/assets/img/banner.jpg", 
  type = 'website', 
  articleDate,
  activeNav
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/assets/img/logo.png" />
  
  <SEO {title} {description} {image} {type} {articleDate} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  
  <script defer src="https://cloud.umami.is/script.js" data-website-id="2de0cd59-a747-4d4a-898e-5b2ff8cee015"></script>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0F172A" />

  <!-- Supabase JS Library -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>

  <slot name="head" />
</head>
<body class="bg-bg text-text font-body">
  <!-- Auth Modals -->
  <div id="auth-modal" class="search-modal-overlay">
    <div class="search-modal auth-modal-content">
      <div class="sm-header">
        <h4 id="auth-modal-title">{t('auth.title')}</h4>
        <button class="sm-close" id="auth-modal-close">&times;</button>
      </div>
      <div class="sm-body">
        <form id="auth-form" class="flex flex-col gap-4 p-6">
          <input type="email" id="auth-email" placeholder={t('auth.email')} required class="px-4 py-3 bg-white/5 border border-white/10 text-white outline-none focus:border-blue-3 transition-colors">
          <input type="password" id="auth-password" placeholder={t('auth.password')} required class="px-4 py-3 bg-white/5 border border-white/10 text-white outline-none focus:border-blue-3 transition-colors">
          <input type="password" id="auth-confirm-password" placeholder={t('auth.confirmPassword')} class="px-4 py-3 bg-white/5 border border-white/10 text-white outline-none focus:border-blue-3 transition-colors hidden">
          
          <button type="submit" id="auth-submit-btn" class="btn-primary py-3 font-bold tracking-wide">{t('auth.continue')}</button>
          
          <div class="relative my-2">
            <div class="absolute inset-0 flex items-center"><span class="w-full border-t border-white/10"></span></div>
            <div class="relative flex justify-center text-xs uppercase"><span class="bg-[#0f172a] px-2 text-dim">{t('auth.or')}</span></div>
          </div>

          <button type="button" id="github-auth-btn" class="flex items-center justify-center gap-3 py-3 bg-white text-black font-bold hover:bg-white/90 transition-colors">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.181-1.305.472-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            GitHub
          </button>

          <p class="text-xs text-dim text-center mt-2">
            <span id="auth-switch-text">{t('auth.noAccount')}</span>
            <button type="button" id="auth-switch-btn" class="text-blue-3 hover:underline">{t('auth.signup')}</button>
          </p>
          <div id="auth-error" class="text-xs text-red-500 mt-2 text-center hidden"></div>
        </form>
      </div>
    </div>
  </div>

  <nav>
    <div class="logo-container">
      <a href="/">
        <img src="/assets/img/biglogo.png" alt="HORACLE CAPITAL Logo" />
      </a>
    </div>
    <div class="nav-links" id="nav-links">
      <button class="menu-close" id="menu-close" aria-label="Fermer le menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      
      <!-- Primary Navigation (Center) -->
      <div class="nav-center">
        <a href={l("/")} class:list={[ { 'active': activeNav === 'home' } ]}>{t('nav.home')}</a>
        
        <!-- Desktop Dropdown / Mobile Direct Links -->
        <div class="nav-dropdown hide-mobile">
          <button class="nav-dropdown-trigger">
            {t('nav.analyses')}
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="6 9 12 15 18 9"></polyline></svg>
          </button>
          <div class="nav-dropdown-content">
            <a href={l("/reports")} class:list={[ { 'active': activeNav === 'reports' } ]}>{t('nav.reports')}</a>
            <a href={l("/research")} class:list={[ { 'active': activeNav === 'research' } ]}>{t('nav.research')}</a>
            <a href={l("/portfolio")} class:list={[ { 'active': activeNav === 'portfolio' } ]}>{t('nav.portfolio')}</a>
          </div>
        </div>

        <!-- Mobile Only Direct Links -->
        <a href={l("/reports")} class="show-mobile" class:list={[ { 'active': activeNav === 'reports' } ]}>{t('nav.reports')}</a>
        <a href={l("/research")} class="show-mobile" class:list={[ { 'active': activeNav === 'research' } ]}>{t('nav.research')}</a>
        <a href={l("/portfolio")} class="show-mobile" class:list={[ { 'active': activeNav === 'portfolio' } ]}>{t('nav.portfolio')}</a>

        <a href={l("/academy")} class:list={[ "flex items-center gap-1", { 'active': activeNav === 'academy' } ]}>{t('nav.academy')} <span class="nav-badge-new">NEW</span></a>
        <a href={l("/about")} class:list={[ { 'active': activeNav === 'about' } ]}>{t('nav.about')}</a>
      </div>
      
      <!-- Secondary Actions (Right) -->
      <div class="nav-right">
        <form class="nav-search" id="global-search-form" action="#">
          <input type="text" placeholder={t('nav.search')} aria-label={t('nav.search')} />
          <button type="submit" aria-label="Search" class="nav-search-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
          </button>
        </form>

        <!-- Language Picker -->
        <div class="nav-lang">
          <LanguagePicker />
        </div>

        <!-- Auth Links -->
        <div class="nav-auth" id="auth-nav">
          <button id="login-btn" class="nav-auth-btn">{t('nav.login')}</button>
          <div id="user-nav" class="hidden flex items-center gap-4">
            <a href={l("/account")} class:list={[ "nav-link-account", { 'active': activeNav === 'account' } ]}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
              {t('nav.account')}
            </a>
            <button id="logout-btn" class="nav-logout-icon" title={t('nav.logout')}>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"></polyline><line x1="21" y1="12" x2="9" y2="12"></line></svg>
            </button>
          </div>
        </div>
      </div>
    </div>
    <button class="menu-toggle" id="menu-toggle" aria-label="Ouvrir le menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </nav>
  <div id="nav-overlay" class="nav-overlay"></div>

  <!-- Notification Toast -->
  <div id="notification-toast" class="fixed bottom-8 right-8 z-[2000] translate-y-20 opacity-0 transition-all duration-500 pointer-events-none">
    <div class="bg-dark border border-blue-3/50 px-8 py-4 shadow-2xl flex items-center gap-4">
      <div class="w-2 h-2 rounded-full bg-blue-3 cs-pulse"></div>
      <p id="notification-message" class="font-mono text-[0.65rem] uppercase tracking-widest text-white"></p>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <script define:vars={{ inactivityMsg: t('toast.inactivity') }}>
    // Handle inactivity logout message
    window.addEventListener('DOMContentLoaded', () => {
      const urlParams = new URLSearchParams(window.location.search);
      if (urlParams.get('reason') === 'inactivity') {
        const toast = document.getElementById('notification-toast');
        const message = document.getElementById('notification-message');
        if (toast && message) {
          message.textContent = inactivityMsg;
          toast.classList.remove('translate-y-20', 'opacity-0');
          toast.classList.add('translate-y-0', 'opacity-100');
          
          setTimeout(() => {
            toast.classList.add('translate-y-20', 'opacity-0');
            toast.classList.remove('translate-y-0', 'opacity-100');
            // Clean URL
            const newUrl = window.location.pathname;
            window.history.replaceState({}, document.title, newUrl);
          }, 5000);
        }
      }
    });
  </script>

  <section class="newsletter-section py-24 px-5 border-t border-border-dk bg-dark">
      <div class="container max-w-[800px] text-center">
        <h2 class="font-head text-4xl md:text-5xl text-white mb-6 tracking-tight">{t('newsletter.title')}</h2>
        <p class="mb-12 text-lg max-w-2xl mx-auto text-white/60">{t('newsletter.description')}</p>
        
        <form id="api-newsletter-form" action="https://fcfd001f.sibforms.com/serve/MUIFAMsHK_ThjVdJrUwMK-YVva9D-V6Sy5_qwv9w7R-BSFNofF9FNnLIyHrejN60zuHn5ieeNlyQVcktmVWsY-2KSC0nROM37etiiX9ed1ETcuRNeIhUyctsmaKrhiHSvrzJtm_m8HdQ1S02yREYcYi1T6MdyApQ7JoRB9uQGp5pxRVZJ5dQVG0mKqPhTYnuL3OM9bVMjFyWNwReeg==" method="POST" class="max-w-[500px] mx-auto">
          <div class="flex flex-col sm:flex-row gap-0">
            <input type="email" name="EMAIL" id="subscriber-email" placeholder={t('newsletter.placeholder')} required
                   class="flex-1 px-6 py-4 bg-white/5 border border-white/10 text-white font-mono outline-none rounded-none text-sm transition-all focus:border-blue-3 focus:bg-white/10">
            <button type="submit" id="submit-btn" class="btn-primary border-none cursor-pointer px-10 py-5 font-mono text-[0.7rem] uppercase tracking-[0.2em] sm:border-l-0" style="border-radius:0;">
              {t('newsletter.button')}
            </button>
          </div>
          <p id="subscription-status" class="mt-6 font-mono text-[0.55rem] uppercase tracking-widest text-dim min-h-[1.2em]"></p>
        </form>
      </div>
    </section>

  <footer>
    <div class="footer-top">
      <p>&copy; {new Date().getFullYear()} HORACLE CAPITAL</p>
      <div class="footer-links">
        <a href={l("/about")}>{t('footer.about')}</a>
        <a href={l("/mentions-legales")}>{t('footer.legal')}</a>
        <a href={l("/reports")}>{t('footer.reports')}</a>
        <a href="https://www.instagram.com/horacle_capital" target="_blank">Instagram</a>
        <a href="https://www.linkedin.com/in/l%C3%A9o-lombardini-418018280/" target="_blank">LinkedIn</a>
        <a href="https://youtube.com/@lbrd_leo" target="_blank">YouTube</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-disclaimer">{t('footer.disclaimer')}</p>
    </div>
  </footer>

  <!-- Newsletter Popup -->
  <div id="newsletter-popup" class="newsletter-popup-overlay">
    <div class="newsletter-popup">
      <button id="close-popup" class="popup-close">&times;</button>
      <div class="popup-content">
        <div class="popup-header">
          <span class="popup-tag">{t('popup.tag')}</span>
          <h2 class="font-head">{t('popup.title')}</h2>
          <p>{t('popup.desc')}</p>
        </div>
        <form action="https://fcfd001f.sibforms.com/serve/MUIFAMsHK_ThjVdJrUwMK-YVva9D-V6Sy5_qwv9w7R-BSFNofF9FNnLIyHrejN60zuHn5ieeNlyQVcktmVWsY-2KSC0nROM37etiiX9ed1ETcuRNeIhUyctsmaKrhiHSvrzJtm_m8HdQ1S02yREYcYi1T6MdyApQ7JoRB9uQGp5pxRVZJ5dQVG0mKqPhTYnuL3OM9bVMjFyWNwReeg==" method="POST" class="popup-form">
          <input type="email" name="EMAIL" placeholder={t('newsletter.placeholder')} required class="popup-input" />
          <button type="submit" class="btn-primary w-full justify-center py-4 uppercase tracking-widest text-xs">{t('newsletter.button')}</button>
        </form>
        <p class="popup-footer">{t('popup.footer')}</p>
      </div>
    </div>
  </div>

  <script is:inline>
    // Newsletter Popup Logic
    window.addEventListener('load', () => {
      const popup = document.getElementById('newsletter-popup');
      const closeBtn = document.getElementById('close-popup');
      const hasClosed = localStorage.getItem('newsletter_popup_closed');
      
      if (!hasClosed) {
        setTimeout(() => {
          popup.classList.add('active');
        }, 10000); // Show after 10 seconds
      }

      closeBtn.addEventListener('click', () => {
        popup.classList.remove('active');
        localStorage.setItem('newsletter_popup_closed', 'true');
      });

      popup.addEventListener('click', (e) => {
        if (e.target === popup) {
          popup.classList.remove('active');
          localStorage.setItem('newsletter_popup_closed', 'true');
        }
      });
    });
  </script>

  <FeedbackForm />
  <script is:inline src="/main.js"></script>
</body>
</html>

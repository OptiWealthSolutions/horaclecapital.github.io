---
import SEO from '../components/SEO.astro';

export interface Props {
	title?: string;
	description?: string;
	image?: string;
	type?: 'website' | 'article';
	articleDate?: string;
	activeNav?: 'home' | 'reports' | 'research' | 'about' | 'capitalis' | 'academy';
}

const { 
  title = "HORACLE CAPITAL | Analyse Macro & Finance Quantitative", 
  description = "Horacle Capital est une structure de recherche spécialisée dans l'analyse macroéconomique et la modélisation quantitative des marchés financiers.", 
  image = "https://horaclecapital.com/assets/img/banner.jpg", 
  type = 'website', 
  articleDate,
  activeNav
} = Astro.props;
---

<!doctype html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/png" href="/assets/img/logo.png" />
  
  <SEO {title} {description} {image} {type} {articleDate} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/style.css" />
  
  <script defer src="https://cloud.umami.is/script.js" data-website-id="2de0cd59-a747-4d4a-898e-5b2ff8cee015"></script>
  <link rel="manifest" href="/manifest.json" />
  <meta name="theme-color" content="#0F172A" />

  <slot name="head" />
</head>
<body class="bg-bg text-text font-body">
  <nav>
    <div class="logo-container">
      <a href="/">
        <img src="/assets/img/biglogo.png" alt="HORACLE CAPITAL Logo" />
      </a>
    </div>
    <div class="nav-links" id="nav-links">
      <button class="menu-close" id="menu-close" aria-label="Fermer le menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
      </button>
      <a href="/" class:list={[ { 'active': activeNav === 'home' } ]}>Home</a>
      <a href="/reports" class:list={[ { 'active': activeNav === 'reports' } ]}>Rapports</a>
      <a href="/research" class:list={[ { 'active': activeNav === 'research' } ]}>Recherches</a>
      <a href="/about" class:list={[ { 'active': activeNav === 'about' } ]}>À Propos</a>
      <a href="/pages/capitalis" class:list={[ "flex items-center gap-1", { 'active': activeNav === 'capitalis' } ]}>Capitalis <span class="nav-badge">APP</span></a>
      <a href="/academy" class:list={[ "flex items-center gap-1", { 'active': activeNav === 'academy' } ]}>Academy <span class="nav-badge-new">NEW</span></a>
      <a href="https://youtube.com/@lbrd_leo?si=t6s5xkQprmXiBvE7" target="_blank">YouTube</a>
      <form class="nav-search" id="global-search-form" action="#">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        <input type="text" placeholder="Rechercher..." aria-label="Rechercher sur le site" />
      </form>
    </div>
    <button class="menu-toggle" id="menu-toggle" aria-label="Ouvrir le menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>
  </nav>
  <div class="nav-overlay" id="nav-overlay"></div>

  <main>
    <slot />
  </main>

  <section class="newsletter-section py-20 px-5 border-t border-border-dk">
      <div class="container max-w-[600px] text-center">
        <h2 class="font-head text-3xl font-normal text-white mb-4 tracking-tight">Newsletter</h2>
        <p class="mb-8 text-[0.95rem]" style="color:rgba(255,255,255,0.55);">Soyez notifié de nos dernières analyses et publications quantitatives directement dans votre boîte de réception.</p>
        <form id="api-newsletter-form" action="https://fcfd001f.sibforms.com/serve/MUIFACcPg2uWGNBAbU4cSDprnElbk1FRV2qwGwIxfu8WogfqGAXSolvDvkbxEJWPch_qaBrUcpsJZw05rutTpZXGsO7NyU4u3KIv1PMY0Kh5ktXIqooAEmA1HDMlHA_hvlNcg0DT492kAYvqOyZArsMV5tUnWgvrl5i0LgCv2U2mfMW79aZTHZPlAWOrFZ81eecgVmzuzpvO98G45Q==" method="POST" class="flex flex-col w-full">
          <div class="flex w-full flex-row">
            <input type="email" name="EMAIL" id="subscriber-email" placeholder="Adresse e-mail" required
                   style="flex:1;padding:14px 16px;background:rgba(255,255,255,0.07);border:1px solid rgba(255,255,255,0.12);border-right:none;color:#fff;font-family:var(--ff-body);outline:none;transition:border-color .2s;border-radius:7px 0 0 7px;"
                   onfocus="this.style.borderColor='rgba(96,165,250,0.5)'" onblur="this.style.borderColor='rgba(255,255,255,0.12)'">
            <button type="submit" id="submit-btn" class="btn-primary border-none cursor-pointer justify-center whitespace-nowrap" style="border-radius:0 7px 7px 0;">
              S'abonner
            </button>
          </div>
          <p id="subscription-status" class="mt-4 font-sans text-xs uppercase tracking-widest min-h-[1.2em]" style="color:rgba(255,255,255,0.5)"></p>
        </form>
      </div>
    </section>

  <footer>
    <div class="footer-top">
      <p>&copy; {new Date().getFullYear()} HORACLE CAPITAL</p>
      <div class="footer-links">
        <a href="/about">À Propos</a>
        <a href="/mentions_legales">Mentions Légales</a>
        <a href="/reports">Rapports</a>
        <a href="https://www.instagram.com/horacle_capital" target="_blank">Instagram</a>
        <a href="https://www.linkedin.com/in/l%C3%A9o-lombardini-418018280/" target="_blank">LinkedIn</a>
        <a href="https://youtube.com/@lbrd_leo" target="_blank">YouTube</a>
      </div>
    </div>
    <div class="footer-bottom">
      <p class="footer-disclaimer">Avertissement sur les risques : Le trading et l'investissement sur les marchés financiers comportent un niveau de risque élevé et peuvent ne pas convenir à tous les investisseurs. Les performances passées ne préjugent pas des performances futures. Le contenu de ce site est fourni à titre exclusivement informatif et ne constitue en aucun cas un conseil en investissement. Horacle Capital ne saurait être tenu responsable de toute perte ou dommage découlant de la confiance accordée aux informations contenues sur ce site.</p>
    </div>
  </footer>

  <script is:inline src="/main.js"></script>
</body>
</html>

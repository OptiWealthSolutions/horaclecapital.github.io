---
import { languages } from '../i18n/ui';
import { getLangFromUrl } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const targetLang = lang === 'fr' ? 'en' : 'fr';

const flags: Record<string, string> = {
  fr: '🇫🇷',
  en: '🇬🇧',
};
const labels: Record<string, string> = {
  fr: 'FR',
  en: 'EN',
};

// Function to generate the URL for the other language
const getLocalizedPath = (l: string) => {
  // Strip a trailing ".html" (build.format:'file') so the `/en` root resolves correctly.
  const path = Astro.url.pathname.replace(/\.html$/, '');
  const segments = path.split('/');

  // If the current path already has a locale prefix
  if (segments[1] in languages) {
    if (l === 'fr') {
        // Remove 'en' prefix for default language
        return path.replace(/^\/en/, '') || '/';
    }
    segments[1] = l;
    return segments.join('/');
  } else {
    // If it's the default language (no prefix)
    if (l === 'fr') return path || '/';
    return `/${l}${path === '/' ? '' : path}`;
  }
};
---

<div class="lang-picker">
  <a
    href={getLocalizedPath(targetLang)}
    class="lang-link"
    title={targetLang === 'fr' ? 'Passer en français' : 'Switch to English'}
    aria-label={targetLang === 'fr' ? 'Passer en français' : 'Switch to English'}
  >
    <svg class="lang-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="2" y1="12" x2="22" y2="12"></line><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path></svg>
    <span class="lang-text">{targetLang === 'fr' ? 'Français' : 'English'}</span>
  </a>
</div>

<style>
  .lang-picker {
    display: flex;
    align-items: center;
  }
  .lang-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--white);
    text-decoration: none;
    transition: color 0.2s;
    padding: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.9rem;
    font-weight: 500;
  }
  .lang-icon {
    color: var(--dim);
    transition: color 0.2s;
  }
  .lang-text {
    /* Optional: hidden on very small screens if needed, but keeping it visible to match reference */
  }
  .lang-link:hover {
    color: var(--blue-3);
  }
  .lang-link:hover .lang-icon {
    color: var(--blue-3);
  }
</style>

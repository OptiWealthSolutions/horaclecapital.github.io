---
export interface Props {
  lang?: 'fr' | 'en';
}
const { lang = 'fr' } = Astro.props;

const faqsFR = [
  {
    question: "Qu'est-ce que l'analyse macroéconomique ?",
    answer: "L'analyse macroéconomique consiste à étudier les indicateurs économiques globaux tels que le PIB, l'inflation (CPI), le chômage et les taux d'intérêt pour comprendre la santé d'une économie et anticiper les mouvements des marchés financiers."
  },
  {
    question: "Comment Horacle Capital utilise-t-il les modèles quantitatifs ?",
    answer: "Nous utilisons des modèles mathématiques avancés et le scoring multifactoriel pour filtrer le bruit du marché et identifier des régimes de marché spécifiques où les probabilités de succès sont asymétriques."
  },
  {
    question: "Quelle est la différence entre Horacle Academy et vos rapports ?",
    answer: "Les rapports sont des analyses hebdomadaires de l'actualité des marchés, tandis que l'Academy est un programme de mentorat structuré conçu pour enseigner les compétences fondamentales en macroéconomie et en finance quantitative."
  },
  {
    question: "Vos analyses constituent-elles des conseils en investissement ?",
    answer: "Non. Horacle Capital fournit des recherches et des analyses à but éducatif et informatif. Chaque investisseur doit effectuer ses propres recherches ou consulter un conseiller financier agréé avant de prendre des décisions d'investissement."
  }
];

const faqsEN = [
  {
    question: "What is macroeconomic analysis?",
    answer: "Macroeconomic analysis consists of studying global economic indicators such as GDP, inflation (CPI), unemployment, and interest rates to understand the health of an economy and anticipate movements in financial markets."
  },
  {
    question: "How does Horacle Capital use quantitative models?",
    answer: "We use advanced mathematical models and multifactor scoring to filter market noise and identify specific market regimes where the probabilities of success are asymmetric."
  },
  {
    question: "What is the difference between Horacle Academy and your reports?",
    answer: "Reports are weekly analyses of current market events, while the Academy is a structured mentorship program designed to teach core competencies in macroeconomics and quantitative finance."
  },
  {
    question: "Do your analyses constitute investment advice?",
    answer: "No. Horacle Capital provides research and analysis for educational and informational purposes. Each investor must conduct their own research or consult a licensed financial advisor before making investment decisions."
  }
];

const faqs = lang === 'en' ? faqsEN : faqsFR;
const sectionLabel = lang === 'en' ? 'Frequently Asked Questions' : 'Questions Fréquentes';

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<section class="faq-section py-16 bg-bg-2 border-t border-border">
    <div class="container">
        <div class="section-rule mb-12">
            <h2 class="section-label">{sectionLabel}</h2>
            <div class="rule-line"></div>
        </div>
        
        <div class="max-w-3xl mx-auto">
            <div class="grid gap-4">
                {faqs.map((faq, index) => (
                    <details class="faq-item group bg-white border border-border p-6 cursor-pointer transition-all duration-300 hover:border-blue-3">
                        <summary class="flex items-center justify-between list-none font-head text-xl text-text">
                            {faq.question}
                            <span class="faq-icon text-blue-3 group-open:rotate-180 transition-transform duration-300">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                            </span>
                        </summary>
                        <div class="mt-4 text-off leading-relaxed prose prose-sm">
                            <p>{faq.answer}</p>
                        </div>
                    </details>
                ))}
            </div>
        </div>
    </div>
</section>

<style>
    summary::-webkit-details-marker {
        display: none;
    }
    
    .faq-item[open] {
        border-color: var(--blue-3);
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.05);
    }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import MacroFAQ from '../components/MacroFAQ.astro';

const title = 'HORACLE CAPITAL | Analyse Macroéconomique & Finance Quantitative';
const description = "Horacle Capital : Recherche indépendante en macroéconomie et finance quantitative. Analyses hebdomadaires, modèles de scoring et mentorat stratégique pour investisseurs.";
---

<BaseLayout {title} {description} activeNav="home">
    <header class="hero hero-index text-center flex flex-col items-center justify-center min-h-[90vh] bg-dark relative overflow-hidden border-b border-border-dk">
      <h1 class="sr-only">Analyse Macroéconomique & Finance Quantitative | Horacle Capital</h1>
      
      <!-- Impeccable Aesthetic Background -->
      <div class="absolute inset-0 pointer-events-none z-0">
        <!-- Subtle Grid -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 40px 40px;"></div>
        <!-- Soft glowing radial gradients -->
        <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-blue-3/10 blur-[120px] rounded-[100%]"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-2/5 blur-[100px] rounded-full"></div>
      </div>

      <div class="hero-inner flex flex-col items-center justify-center relative z-10 w-full px-6">
        <div class="flex flex-col items-center justify-center w-full max-w-5xl mx-auto">
          
          <div class="mb-12 relative reveal">
            <img src="/assets/img/logo_ban.svg" alt="HORACLE CAPITAL" class="w-full max-w-[360px] md:max-w-[650px] lg:max-w-[800px] min-[1500px]:max-w-[1000px] drop-shadow-2xl brightness-0 invert" />
          </div>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 w-full px-4 sm:px-0 reveal reveal-delay-1">
            <a href="/reports" class="btn-primary w-full sm:w-auto justify-center text-sm md:text-base lg:text-lg px-6 md:px-8 py-4 md:py-5 shadow-xl hover:shadow-blue-3/20 flex items-center gap-3">
              Nos rapports macro
              <svg width="18" height="18" viewBox="0 0 14 14" fill="none" class="w-4 h-4 md:w-5 md:h-5"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/research" class="w-full sm:w-auto justify-center text-sm md:text-base lg:text-lg px-6 md:px-8 py-4 md:py-5 shadow-xl flex items-center gap-3 border border-white/20 text-white hover:bg-white/5 transition-colors font-bold font-sans tracking-wide">
              Nos recherches
              <svg width="18" height="18" viewBox="0 0 14 14" fill="none" class="w-4 h-4 md:w-5 md:h-5"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <p class="hero-sub hidden md:flex items-center justify-center gap-4 text-xs md:text-sm lg:text-base mt-16 font-mono text-white/40 tracking-[0.2em] uppercase reveal reveal-delay-2">
            <span>Analyse Macroéconomique</span>
            <span class="w-1 h-1 rounded-full bg-blue-3"></span>
            <span>Finance Quantitative</span>
            <span class="w-1 h-1 rounded-full bg-blue-3"></span>
            <span>Stratégie de Marché</span>
          </p>
          
        </div>
      </div>
    </header>

    <main>
      <!-- ÉCOSYSTÈME ASYMÉTRIQUE -->
      <section class="py-12 border-t border-border" style="background:var(--bg-2);">
        <div class="container">
          <div class="section-rule mb-12">
            <h2 class="section-label">L'Écosystème Horacle</h2>
            <div class="rule-line"></div>
          </div>

          <div class="eco-grid">
            <!-- Portfolio (Replaces Academy) -->
            <a href="/portfolio" class="eco-card academy reveal">
              <div class="eco-image-bg" style="background-image: url('https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=1200&q=80');"></div>
              <span class="eco-label">Exécution Stratégique</span>
              <h3 class="eco-title">Nos thèses d'investissement</h3>
              <p class="eco-desc">L'application directe de notre recherche macroéconomique. Des convictions asymétriques sur les actions, devises et matières premières, avec une gestion stricte du risque.</p>
              <span class="eco-link">Voir nos convictions <span>→</span></span>
            </a>

            <!-- Research -->
            <a href="/research" class="eco-card featured dark reveal reveal-delay-1">
              <div class="eco-image-bg" style="background-image: url('/assets/img/notebook_banner.jpg');"></div>
              <span class="eco-label">Finance Quantitative</span>
              <h3 class="eco-title">Nos recherches</h3>
              <p class="eco-desc">Modélisation statistique et analyse fondamentale. Découvrez nos cadres mathématiques pour anticiper les régimes de volatilité et les cycles structurels.</p>
              <span class="eco-link">Consulter nos recherches <span>→</span></span>
            </a>

            <!-- Reports -->
            <a href="/reports" class="eco-card mission reveal reveal-delay-2">
              <span class="eco-label">Veille Stratégique</span>
              <h3 class="eco-title">Nos rapports</h3>
              <p class="eco-desc">Recevez chaque semaine nos analyses de haute précision sur l'actualité macroéconomique. Un éclairage indépendant pour comprendre les enjeux financiers globaux.</p>
              <span class="eco-link">Accéder aux rapports <span>→</span></span>
            </a>
          </div>
        </div>
      </section>

      <!-- QUI SOMMES-NOUS : PHILOSOPHY -->
      <section id="about" class="py-32 bg-dark relative border-y border-white/10 overflow-hidden">
        <div class="container relative z-10">
          <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
            <!-- Left Column: Text -->
            <div class="reveal">
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.4em] text-blue-3 mb-6 block">La Philosophie</span>
              <h2 class="font-head text-5xl md:text-7xl text-white mb-8 leading-[1.05] tracking-tight">Horacle Capital</h2>
              <div class="w-16 h-1 bg-blue-3 mb-10"></div>
              
              <p class="text-xl text-white/90 leading-relaxed font-light mb-8 max-w-lg">
                Nous ne sommes pas un média. Nous sommes une cellule de recherche indépendante dédiée à la détection d'asymétries de marché.
              </p>
              <div class="flex flex-col gap-6 text-white/60 text-base leading-relaxed font-light max-w-lg">
                <p>Notre approche opère à l'intersection de la macroéconomie fondamentale et de la finance quantitative.</p>
                <p>Nous cartographions les flux de liquidités mondiaux et les régimes de volatilité pour anticiper les cycles structurels, en concevant des cadres probabilistes qui viennent éprouver nos convictions avec une totale objectivité. Le signal pur, pas le bruit.</p>
              </div>
            </div>

            <!-- Right Column: Logo -->
            <div class="reveal reveal-delay-1 flex justify-center lg:justify-end">
              <div class="relative w-full max-w-[500px] aspect-square flex items-center justify-center p-8">
                <!-- Decorative pulse/glow behind logo -->
                <div class="absolute inset-0 bg-blue-3/5 rounded-full blur-[100px] animate-pulse"></div>
                <div class="absolute inset-4 border border-white/5 rounded-full"></div>
                <div class="absolute inset-12 border border-white/5 rounded-full border-dashed animate-[spin_60s_linear_infinite]"></div>
                
                <img src="/assets/img/biglogo.png" alt="Horacle Capital Logo" class="relative z-10 w-48 md:w-72 lg:w-80 opacity-90 drop-shadow-2xl" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ACADEMY & PORTFOLIO : DUAL PILLARS -->
      <section class="py-32 border-t border-border bg-white relative">
        <div class="container relative z-10">
          <div class="text-center max-w-3xl mx-auto mb-20 reveal">
            <h2 class="font-head text-4xl md:text-5xl text-text mb-6 tracking-tight">De la théorie à l'application</h2>
            <div class="w-16 h-px bg-blue-3 mx-auto mb-6"></div>
            <p class="text-off text-lg leading-relaxed font-sans">
              L'écosystème Horacle Capital repose sur deux piliers majeurs. La transmission de notre méthodologie à travers un programme de mentorat exclusif, et la mise en pratique transparente de notre recherche macroéconomique via nos convictions de marché.
            </p>
          </div>

          <div class="grid lg:grid-cols-2 border border-border shadow-xl reveal reveal-delay-1">
            
            <!-- Academy Side -->
            <article class="p-12 md:p-16 border-b lg:border-b-0 lg:border-r border-border bg-white relative overflow-hidden group">
              <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50 blur-[100px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              <div class="relative z-10 h-full flex flex-col">
                <span class="text-xs uppercase tracking-widest text-blue-3 font-bold mb-8 block font-sans">Éducation Macroéconomique</span>
                <h3 class="font-head text-3xl md:text-4xl text-text mb-6 leading-[1.1] group-hover:text-blue-3 transition-colors">Horacle Academy</h3>
                <p class="text-off text-base leading-relaxed mb-10 flex-1 font-sans">
                  Ne subissez plus les marchés. Apprenez à les anticiper via un <strong class="font-bold text-text">mentorat privé 1-on-1</strong> conçu pour les investisseurs exigeants. Maîtrisez les cycles de liquidité, l'impact des banques centrales et notre framework d'analyse institutionnel.
                </p>
                <div class="pt-8 border-t border-border mt-auto">
                  <a href="/academy" class="inline-flex items-center gap-3 text-sm font-bold text-text group-hover:text-blue-3 transition-colors font-sans">
                    Explorer le programme <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </a>
                </div>
              </div>
            </article>

            <!-- Portfolio Side -->
            <article class="p-12 md:p-16 bg-bg-2 relative overflow-hidden group">
              <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none" style="background-image: radial-gradient(var(--blue-3) 1px, transparent 1px); background-size: 20px 20px;"></div>
              <div class="relative z-10 h-full flex flex-col">
                <span class="text-xs uppercase tracking-widest text-blue-3 font-bold mb-8 block font-sans">Exécution Stratégique</span>
                <h3 class="font-head text-3xl md:text-4xl text-text mb-6 leading-[1.1] group-hover:text-blue-3 transition-colors">Portefeuille Modèle</h3>
                <p class="text-off text-base leading-relaxed mb-10 flex-1 font-sans">
                  L'application directe de notre recherche macroéconomique. Découvrez nos <strong class="font-bold text-text">thèses d'investissement asymétriques</strong> sur les actions, les matières premières et les devises, argumentées et suivies dans le temps avec une gestion stricte du risque.
                </p>
                <div class="pt-8 border-t border-border/50 mt-auto">
                  <a href="/portfolio" class="inline-flex items-center gap-3 text-sm font-bold text-text group-hover:text-blue-3 transition-colors font-sans">
                    Voir nos convictions <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </a>
                </div>
              </div>
            </article>

          </div>
        </div>
      </section>

      <!-- DERNIÈRES PUBLICATIONS (Restore Grid) -->
      <section class="py-12 border-t border-border">
        <div class="container">
          <div class="section-rule mb-12">
            <h2 class="section-label">Dernières Publications</h2>
            <div class="rule-line"></div>
            <a href="/reports" class="rule-link">Tout voir <span>→</span></a>
          </div>

          <div class="grid lg:grid-cols-2 gap-6">

            <a href="/reports/rapport_24_04_26" class="reveal group flex flex-col bg-white border border-border hover:border-orange transition-all duration-300 shadow-sm hover:shadow-md">
              <div class="h-56 overflow-hidden relative border-b border-border">
                <img
                  src="/assets/img/hormuz.jpg"
                  onerror="this.src='/assets/img/banner.jpg'"
                  alt="Tensions géopolitiques Détroit d'Ormuz"
                  class="w-full h-full object-cover opacity-100 group-hover:scale-105 transition-all duration-700">
                <div class="absolute top-4 left-4 flex gap-2">
                  <span class="bg-orange text-white font-sans text-[0.58rem] uppercase tracking-[0.1em] px-3 py-1 font-bold rounded-none">Macro</span>
                  <span class="bg-white text-text border border-border font-sans text-[0.55rem] uppercase tracking-[0.1em] px-2 py-1">Hebdo N°9</span>
                </div>
              </div>
              <div class="p-8 flex-1 flex flex-col">
                <div class="font-sans text-[0.6rem] text-dim mb-3 uppercase tracking-widest">24 Avril 2026</div>
                <h3 class="font-head text-2xl font-semibold text-text mb-4 leading-tight group-hover:text-orange transition-colors">Climat Tendu &amp;<br>Equities au Top</h3>
                <p class="text-off text-[0.9rem] leading-relaxed line-clamp-3 mb-6 flex-1">Revue macro du 20 au 24 avril 2026 : tensions diplomatiques Iran–USA, résistance des marchés actions et lecture des données macroéconomiques clés.</p>
                <div class="inline-flex items-center gap-2 font-sans text-[0.75rem] font-semibold text-orange mt-auto pt-6 border-t border-border">
                  Lire le rapport <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
              </div>
            </a>

            <a href="/reports/rapport_12_04_26" class="reveal reveal-delay-1 group flex flex-col bg-white border border-border hover:border-orange transition-all duration-300 shadow-sm hover:shadow-md">
              <div class="h-56 overflow-hidden relative border-b border-border">
                <img
                  src="https://images.unsplash.com/photo-1541354329998-f4d9a9f9297f?w=800&q=80&auto=format&fit=crop"
                  onerror="this.src='/assets/img/banner.jpg'"
                  alt="Trêve Annoncée et Résistance de l'Inflation"
                  class="w-full h-full object-cover opacity-100 group-hover:scale-105 transition-all duration-700">
                <div class="absolute top-4 left-4 flex gap-2">
                  <span class="bg-orange text-white font-sans text-[0.58rem] uppercase tracking-[0.1em] px-3 py-1 font-bold rounded-none">Macro</span>
                  <span class="bg-white text-text border border-border font-sans text-[0.55rem] uppercase tracking-[0.1em] px-2 py-1">Hebdo N°8</span>
                </div>
              </div>
              <div class="p-8 flex-1 flex flex-col">
                <div class="font-sans text-[0.6rem] text-dim mb-3 uppercase tracking-widest">12 Avril 2026</div>
                <h3 class="font-head text-2xl font-semibold text-text mb-4 leading-tight group-hover:text-orange transition-colors">Trêve Annoncée &amp;<br>Inflation Persistante</h3>
                <p class="text-off text-[0.9rem] leading-relaxed line-clamp-3 mb-6 flex-1">Débrief de la semaine : signaux de pause des banques centrales face à l'inflation persistante et impact de la trêve sur les marchés.</p>
                <div class="inline-flex items-center gap-2 font-sans text-[0.75rem] font-semibold text-orange mt-auto pt-6 border-t border-border">
                  Lire le rapport <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
              </div>
            </a>

          </div>
        </div>
      </section>

      <!-- FAQ SECTION -->
      <MacroFAQ />

    </main>

    <script is:inline>
    (function() {
      var vids = document.querySelectorAll('.hero-vid');
      if (!vids.length) return;
      var cur = 0;
      function tryPlay(v) {
        if (v.readyState === 0) v.load();
        v.play().catch(function() {});
      }
      tryPlay(vids[0]);
      function advance() {
        var prev = cur;
        cur = (cur + 1) % vids.length;
        tryPlay(vids[cur]);
        vids[cur].classList.add('active');
        setTimeout(function() { vids[prev].classList.remove('active'); }, 1800);
        setTimeout(advance, 15000);
      }
      setTimeout(advance, 15000);
    })();
    </script>
</BaseLayout>
    </script>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'HORACLE CAPITAL | Analyse Macroéconomique & Finance Quantitative';
const description = "Horacle Capital : Recherche indépendante en macroéconomie et finance quantitative. Analyses hebdomadaires, modèles de scoring et mentorat stratégique pour investisseurs.";
---

<BaseLayout {title} {description} activeNav="home">
    <style>
      @media (max-width: 1649px) {
        .hero-visual {
          display: none !important;
        }
        .hero-split {
          grid-template-columns: 1fr !important;
        }
        .hero-content {
          margin: 0 auto;
          text-align: center;
          align-items: center;
        }
        .hero-actions {
          justify-content: center;
        }
      }
    </style>
    <header class="hero hero-index">
      <h1 class="sr-only">Analyse Macroéconomique & Finance Quantitative | Horacle Capital</h1>
      <!-- Static fallback visible only if all videos fail to load -->
      <img src="/assets/img/banner.jpg" alt="Analyste financier travaillant sur des rapports macroéconomiques Horacle Capital" class="hero-bg" aria-hidden="true" />
      <!-- Night city video reel — 3 clips crossfade every 15s -->
      <div class="hero-bg-videos" aria-hidden="true">
        <video class="hero-vid active" muted loop playsinline preload="auto">
          <source src="https://videos.pexels.com/video-files/9921281/9921281-uhd_2560_1440_30fps.mp4" type="video/mp4">
        </video>
        <video class="hero-vid" muted loop playsinline preload="none">
          <source src="https://videos.pexels.com/video-files/27635324/12190054_1920_1080_30fps.mp4" type="video/mp4">
        </video>
        <video class="hero-vid" muted loop playsinline preload="none">
          <source src="https://videos.pexels.com/video-files/34781215/14745388_2560_1440_30fps.mp4" type="video/mp4">
        </video>
      </div>
      <div class="hero-inner hero-split">
        <div class="hero-content">
          <div>
            <img src="/assets/img/logo_ban.svg" alt="HORACLE CAPITAL" class="w-full max-w-[320px] md:max-w-[500px] lg:max-w-[650px] min-[1500px]:max-w-[800px]" />
          </div>
          <p class="hero-sub">
            Analyse Macroéconomique<span class="dot">·</span>Finance Quantitative<span class="dot">·</span>Stratégie de Marché
          </p>
          <div class="hero-actions">
            <a href="/reports" class="btn-primary">
              Nos rapports macro
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href="/research" class="btn-ghost">
              Nos recherches
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>
        </div>

        <div class="hero-visual">
          <div class="hero-visual-card">
            <div class="hero-visual-glow"></div>
            
            <div class="chart-header">
              <div style="display:flex;align-items:center;gap:9px;">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--blue-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3"/></svg>
                <span class="chart-title">Modèle Prédictif</span>
              </div>
              <div class="chart-live"><div class="live-dot"></div>Live</div>
            </div>
            
            <div class="chart-container">
              <svg class="chart-svg" viewBox="0 0 500 250" preserveAspectRatio="none">
                <defs>
                  <linearGradient id="lineGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                    <stop offset="0%" stop-color="var(--blue-3)" />
                    <stop offset="100%" stop-color="var(--blue-2)" />
                  </linearGradient>
                </defs>
                
                <!-- Lignes de repère -->
                <line x1="0" y1="50" x2="500" y2="50" class="grid-line" />
                <line x1="0" y1="100" x2="500" y2="100" class="grid-line" />
                <line x1="0" y1="150" x2="500" y2="150" class="grid-line" />
                <line x1="0" y1="200" x2="500" y2="200" class="grid-line" />

                <!-- Courbe animée -->
                <path class="chart-path" d="M 0 200 C 80 200, 120 120, 180 130 C 240 140, 280 50, 340 70 C 400 90, 440 20, 480 30" fill="none" stroke="url(#lineGrad)" stroke-width="4" stroke-linecap="round" />

                <!-- Points d'informations -->
                <g class="chart-point point-1">
                  <rect x="175" y="125" width="10" height="10" fill="var(--bg)" stroke="var(--blue-3)" stroke-width="2" />
                  <rect x="130" y="90" width="100" height="26" rx="0" class="chart-tooltip-bg" />
                  <text x="180" y="107" class="chart-tooltip-text">Signal Achat</text>
                </g>

                <g class="chart-point point-2">
                  <rect x="335" y="65" width="10" height="10" fill="var(--bg)" stroke="var(--blue-3)" stroke-width="2" />
                  <rect x="290" y="30" width="100" height="26" rx="0" class="chart-tooltip-bg" />
                  <text x="340" y="47" class="chart-tooltip-text">Breakout Vol.</text>
                </g>

                <g class="chart-point point-3">
                  <rect x="475" y="25" width="10" height="10" fill="var(--bg)" stroke="var(--blue-3)" stroke-width="2" />
                  <rect x="390" y="45" width="100" height="26" rx="0" class="chart-tooltip-bg" />
                  <text x="440" y="62" class="chart-tooltip-text">Cible Atteinte</text>
                </g>
              </svg>
            </div>

            <div class="chart-footer">
              <div class="cf-stat"><span class="cf-label">Rendement</span><span class="cf-val up">+14.2%</span></div>
              <div class="cf-stat" style="align-items:center;"><span class="cf-label">Sharpe</span><span class="cf-val">2.1</span></div>
              <div class="cf-stat" style="align-items:flex-end;"><span class="cf-label">Drawdown</span><span class="cf-val dn">-3.4%</span></div>
            </div>
          </div>
        </div>
      </div>
      <div class="hero-num" aria-hidden="true">N°9</div>
    </header>

    <main>
      <!-- ÉCOSYSTÈME ASYMÉTRIQUE -->
      <section class="py-12 border-t border-border" style="background:var(--bg-2);">
        <div class="container">
          <div class="section-rule mb-12">
            <h2 class="section-label">L'Écosystème Horacle</h2>
            <div class="rule-line"></div>
          </div>

          <div class="eco-grid">
            <!-- Academy -->
            <a href="/academy" class="eco-card academy reveal">
              <div class="eco-image-bg" style="background-image: url('https://images.unsplash.com/photo-1552664730-d307ca884978?auto=format&fit=crop&w=1200&q=80');"></div>
              <span class="eco-label">Formation & Mentorat</span>
              <h3 class="eco-title">Horacle Academy</h3>
              <p class="eco-desc">Maîtrisez les rouages de l'économie mondiale. Un mentorat stratégique pour apprendre à décrypter les cycles de marché et les politiques des banques centrales.</p>
              <span class="eco-link">Explorer les programmes <span>→</span></span>
            </a>

            <!-- Research -->
            <a href="/research" class="eco-card featured dark reveal reveal-delay-1">
              <div class="eco-image-bg" style="background-image: url('/assets/img/notebook_banner.jpg');"></div>
              <span class="eco-label">Finance Quantitative</span>
              <h3 class="eco-title">Nos recherches et convictions</h3>
              <p class="eco-desc">Découvrez nos thèses d'investissement et nos travaux de recherche. Une approche rigoureuse mêlant modélisation statistique et analyse fondamentale approfondie.</p>
              <span class="eco-link">Consulter nos recherches <span>→</span></span>
            </a>

            <!-- Reports -->
            <a href="/reports" class="eco-card mission reveal reveal-delay-2">
              <span class="eco-label">Veille Stratégique</span>
              <h3 class="eco-title">Nos rapports</h3>
              <p class="eco-desc">Recevez chaque semaine nos analyses de haute précision sur l'actualité macroéconomique. Un éclairage indépendant pour comprendre les enjeux financiers globaux.</p>
              <span class="eco-link">Accéder aux rapports <span>→</span></span>
            </a>
          </div>
        </div>
      </section>

      <!-- PRÉSENTATION -->
      <section id="about" class="about-section" style="background:var(--dark); border-top:1px solid var(--border-dk); border-bottom:1px solid var(--border-dk); padding: 32px 0;">
        <div class="container">
          <div class="section-rule" style="border-left:none;">
            <h2 class="section-label" style="color:var(--blue-3);">Présentation</h2>
            <div class="rule-line" style="background:var(--border-dk);"></div>
          </div>
          <div class="about-grid">
            <div class="about-body reveal">
              <h3 class="section-title" style="color:var(--white);">QUI SOMMES-<br>NOUS ?</h3>
              <p style="color:rgba(255,255,255,0.7);">
                <strong style="color:var(--white);">Horacle Capital</strong> est une structure de recherche indépendante spécialisée dans l'analyse macroéconomique et la modélisation quantitative des marchés financiers.
              </p>
              <p style="color:rgba(255,255,255,0.7);">
                Nous publions des <strong style="color:var(--white);">rapports hebdomadaires</strong> stratégiques et proposons un <strong style="color:var(--white);">mentorat privé</strong> pour maîtriser les fondamentaux de l'économie mondiale.
              </p>
              <p style="color:rgba(255,255,255,0.7);">
                Explorez nos <a href="/reports" style="color:var(--blue-3);">Rapports</a> ou nos <a href="/research" style="color:var(--blue-3);">Recherches</a>.
              </p>
              <div class="disclaimer" style="color:rgba(255,255,255,0.4); border-top-color:var(--border-dk);">
                ⚠ Rien de ce qui est publié ici ne constitue un conseil en investissement.
              </div>
              <div class="socials">
                <a href="https://www.linkedin.com/in/l%C3%A9o-lombardini-418018280/" target="_blank" class="social-pill" style="color:rgba(255,255,255,0.6); border-color:var(--border-dk); background:transparent;">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
                  LinkedIn — Léo Lombardini
                </a>
                <a href="https://youtube.com/@lbrd_leo?si=t6s5xkQprmXiBvE7" target="_blank" class="social-pill" style="color:rgba(255,255,255,0.6); border-color:var(--border-dk); background:transparent;">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"/><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02" fill="currentColor"/></svg>
                  YouTube — @lbrd_leo
                </a>
              </div>
            </div>

            <div class="about-panel reveal reveal-delay-1" style="background:var(--dark-2); border-color:var(--border-dk); box-shadow:none;">
              <div class="panel-header" style="background:var(--dark-3); border-color:var(--border-dk);">
                <div class="panel-dot"></div>
                <span>Notre Méthodologie</span>
              </div>
              <div class="p-10 flex flex-col gap-8 relative">
                <!-- Decorative line -->
                <div class="absolute left-[59px] top-[60px] bottom-[60px] w-px bg-gradient-to-b from-blue-3 via-blue-2 to-transparent opacity-30"></div>
                
                <div class="flex items-center gap-6 relative z-10">
                  <div class="w-10 h-10 rounded-none bg-blue-d border border-blue-3/30 flex items-center justify-center text-blue-3 font-mono text-sm">01</div>
                  <div>
                    <h4 class="text-white font-sans font-bold text-sm uppercase tracking-wider">Macro-Analyse</h4>
                    <p class="text-dim text-xs">Cycles monétaires & politiques des Banques Centrales.</p>
                  </div>
                </div>

                <div class="flex items-center gap-6 relative z-10">
                  <div class="w-10 h-10 rounded-none bg-blue-d border border-blue-3/30 flex items-center justify-center text-blue-3 font-mono text-sm">02</div>
                  <div>
                    <h4 class="text-white font-sans font-bold text-sm uppercase tracking-wider">Filtrage Quantitatif</h4>
                    <p class="text-dim text-xs">Modèles statistiques HMM & scoring multifactoriel.</p>
                  </div>
                </div>

                <div class="flex items-center gap-6 relative z-10">
                  <div class="w-10 h-10 rounded-none bg-blue-d border border-blue-3/30 flex items-center justify-center text-blue-3 font-mono text-sm">03</div>
                  <div>
                    <h4 class="text-white font-sans font-bold text-sm uppercase tracking-wider">Signal de Décision</h4>
                    <p class="text-dim text-xs">Extraction de la valeur pure au milieu du bruit du marché.</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ACADEMY DETAIL -->
      <section class="py-12 border-t border-border bg-gradient-to-b from-bg to-white relative overflow-hidden">
        <div class="container">
          <div class="grid lg:grid-cols-2 gap-12 items-center">
            <div class="reveal">
              <span class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-orange font-bold mb-4 block">Comprendre le Monde Financier</span>
              <h2 class="font-head text-4xl md:text-5xl text-text mb-6 leading-[1.1] tracking-tight">Horacle Academy : Masterclass Macroéconomie</h2>
              <p class="text-off text-lg mb-8 leading-relaxed font-light">
                Ne subissez plus le marché, anticipez-le par une analyse fondamentale rigoureuse. Nous formons ceux qui souhaitent faire le pont entre théorie et réalité du terrain.
              </p>
              <div class="grid gap-4 mb-10">
                <div class="flex items-start gap-4 p-5 bg-bg-2 border border-border rounded-none shadow-sm">
                  <div class="w-8 h-8 bg-orange/10 flex items-center justify-center rounded-none flex-shrink-0">
                    <span class="font-head text-orange text-sm font-bold">01</span>
                  </div>
                  <div>
                    <h4 class="font-sans font-bold text-text text-sm mb-1">Framework Macroéconomique</h4>
                    <p class="text-off text-xs leading-relaxed">Maîtrise des politiques de Banques Centrales et décryptage des indicateurs (CPI, NFP).</p>
                  </div>
                </div>
                <div class="flex items-start gap-4 p-5 bg-bg-2 border border-border rounded-none shadow-sm">
                  <div class="w-8 h-8 bg-orange/10 flex items-center justify-center rounded-none flex-shrink-0">
                    <span class="font-head text-orange text-sm font-bold">02</span>
                  </div>
                  <div>
                    <h4 class="font-sans font-bold text-text text-sm mb-1">Sessions Privées d'Élite</h4>
                    <p class="text-off text-xs leading-relaxed">Un accompagnement sur-mesure pour transformer vos lacunes en avantages compétitifs.</p>
                  </div>
                </div>
              </div>
              <a href="/academy" class="btn-primary" style="padding: 14px 32px; font-size: 0.9rem;">
                Découvrir l'Academy
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left: 8px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </a>
            </div>
            <div class="relative reveal reveal-delay-1">
              <div class="aspect-square bg-dark border border-border-dk overflow-hidden rounded-none max-w-[400px] mx-auto lg:mr-0 flex items-center justify-center" style="box-shadow:none !important;">
                <img src="/assets/img/biglogo.png" alt="Horacle Capital Logo" class="w-full h-full object-contain p-12 transition-all duration-700" style="box-shadow:none !important; filter:none !important;">
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- DERNIÈRES PUBLICATIONS (Restore Grid) -->
      <section class="py-12 border-t border-border">
        <div class="container">
          <div class="section-rule mb-12">
            <h2 class="section-label">Dernières Publications</h2>
            <div class="rule-line"></div>
            <a href="/reports" class="rule-link">Tout voir <span>→</span></a>
          </div>

          <div class="grid lg:grid-cols-2 gap-6">

            <a href="/reports/rapport_24_04_26" class="reveal group flex flex-col bg-white border border-border hover:border-orange transition-all duration-300 shadow-sm hover:shadow-md">
              <div class="h-56 overflow-hidden relative border-b border-border">
                <img
                  src="/assets/img/hormuz.jpg"
                  onerror="this.src='/assets/img/banner.jpg'"
                  alt="Tensions géopolitiques Détroit d'Ormuz"
                  class="w-full h-full object-cover opacity-100 group-hover:scale-105 transition-all duration-700">
                <div class="absolute top-4 left-4 flex gap-2">
                  <span class="bg-orange text-white font-sans text-[0.58rem] uppercase tracking-[0.1em] px-3 py-1 font-bold rounded-none">Macro</span>
                  <span class="bg-white text-text border border-border font-sans text-[0.55rem] uppercase tracking-[0.1em] px-2 py-1">Hebdo N°9</span>
                </div>
              </div>
              <div class="p-8 flex-1 flex flex-col">
                <div class="font-sans text-[0.6rem] text-dim mb-3 uppercase tracking-widest">24 Avril 2026</div>
                <h3 class="font-head text-2xl font-normal text-text mb-4 leading-tight group-hover:text-orange transition-colors">Climat Tendu &amp;<br>Equities au Top</h3>
                <p class="text-off text-[0.9rem] leading-relaxed line-clamp-3 mb-6 flex-1">Revue macro du 20 au 24 avril 2026 : tensions diplomatiques Iran–USA, résistance des marchés actions et lecture des données macroéconomiques clés.</p>
                <div class="inline-flex items-center gap-2 font-sans text-[0.75rem] font-semibold text-orange mt-auto pt-6 border-t border-border">
                  Lire le rapport <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
              </div>
            </a>

            <a href="/reports/rapport_12_04_26" class="reveal reveal-delay-1 group flex flex-col bg-white border border-border hover:border-orange transition-all duration-300 shadow-sm hover:shadow-md">
              <div class="h-56 overflow-hidden relative border-b border-border">
                <img
                  src="https://images.unsplash.com/photo-1541354329998-f4d9a9f9297f?w=800&q=80&auto=format&fit=crop"
                  onerror="this.src='/assets/img/banner.jpg'"
                  alt="Trêve Annoncée et Résistance de l'Inflation"
                  class="w-full h-full object-cover opacity-100 group-hover:scale-105 transition-all duration-700">
                <div class="absolute top-4 left-4 flex gap-2">
                  <span class="bg-orange text-white font-sans text-[0.58rem] uppercase tracking-[0.1em] px-3 py-1 font-bold rounded-none">Macro</span>
                  <span class="bg-white text-text border border-border font-sans text-[0.55rem] uppercase tracking-[0.1em] px-2 py-1">Hebdo N°8</span>
                </div>
              </div>
              <div class="p-8 flex-1 flex flex-col">
                <div class="font-sans text-[0.6rem] text-dim mb-3 uppercase tracking-widest">12 Avril 2026</div>
                <h3 class="font-head text-2xl font-normal text-text mb-4 leading-tight group-hover:text-orange transition-colors">Trêve Annoncée &amp;<br>Inflation Persistante</h3>
                <p class="text-off text-[0.9rem] leading-relaxed line-clamp-3 mb-6 flex-1">Débrief de la semaine : signaux de pause des banques centrales face à l'inflation persistante et impact de la trêve sur les marchés.</p>
                <div class="inline-flex items-center gap-2 font-sans text-[0.75rem] font-semibold text-orange mt-auto pt-6 border-t border-border">
                  Lire le rapport <svg class="w-4 h-4 transform group-hover:translate-x-1 transition-transform" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </div>
              </div>
            </a>

          </div>
        </div>
      </section>

    </main>

    <script is:inline>
    (function() {
      var vids = document.querySelectorAll('.hero-vid');
      if (!vids.length) return;
      var cur = 0;
      function tryPlay(v) {
        if (v.readyState === 0) v.load();
        v.play().catch(function() {});
      }
      tryPlay(vids[0]);
      function advance() {
        var prev = cur;
        cur = (cur + 1) % vids.length;
        tryPlay(vids[cur]);
        vids[cur].classList.add('active');
        setTimeout(function() { vids[prev].classList.remove('active'); }, 1800);
        setTimeout(advance, 15000);
      }
      setTimeout(advance, 15000);
    })();
    </script>
</BaseLayout>

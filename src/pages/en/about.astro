---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SubscribeCTA from '../../components/SubscribeCTA.astro';

const title = 'About Horacle Capital | Macro Expertise & Independent Research';
const description = "Discover Horacle Capital's vision. Founded by Léo Lombardini, our firm combines cutting-edge macroeconomic analysis and quantitative finance for research excellence.";
---

<BaseLayout {title} {description} activeNav="about">
    <header class="page-header relative h-[45vh] flex items-center justify-center overflow-hidden">
      <img src="/assets/img/banner.jpg" alt="Horacle Capital expertise: fundamental analysis and statistical precision" class="header-bg scale-110" aria-hidden="true" />
      <div class="absolute inset-0 bg-dark/40 backdrop-blur-[1px]"></div>
      <div class="relative z-10 text-center px-6">
        <span class="font-mono text-[0.7rem] uppercase tracking-[0.4em] text-blue-3 mb-4 block reveal">The Intelligence Edge</span>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-head text-white mb-6 tracking-tight reveal reveal-delay-1">About</h1>
        <p class="text-lg md:text-xl text-white/80 font-light max-w-2xl mx-auto leading-relaxed reveal reveal-delay-2">Pure signal, extracted at the intersection of macroeconomics and mathematics.</p>
      </div>
    </header>

    <main class="bg-white">
        <!-- Vision Section (Enhanced) -->
        <section class="py-24 md:py-32 border-b border-border relative overflow-hidden">
            <div class="absolute top-0 right-0 w-1/3 h-full bg-bg-2/50 -skew-x-12 translate-x-1/4 pointer-events-none"></div>
            <div class="container max-w-6xl relative z-10">
                <div class="grid lg:grid-cols-12 gap-16 lg:gap-24 items-center">
                    <div class="lg:col-span-6">
                        <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-blue-3 mb-6 block reveal">Our Purpose</span>
                        <h2 class="font-head text-5xl md:text-6xl lg:text-7xl text-text leading-[1.1] tracking-tight mb-8 reveal reveal-delay-1">
                            Horacle Capital: <br/>
                            <span class="text-blue-2">Independence</span><br/>as the standard.
                        </h2>
                        <div class="w-24 h-1.5 bg-blue-3 reveal reveal-delay-2"></div>
                    </div>
                    <div class="lg:col-span-6 flex flex-col gap-10 text-xl text-off font-sans leading-relaxed font-light reveal reveal-delay-3">
                        <p class="border-l-4 border-blue-3/20 pl-8">
                            Horacle Capital is not a financial media outlet. It is a research cell designed for demanding investors who reject media noise and the complacency of consensus analysis.
                        </p>
                        <div class="space-y-6">
                            <p>
                                Our approach rests on a unique synergy: <strong>Macroeconomic Analysis</strong> defines our directional convictions, while <strong>Quantitative Finance</strong> stress-tests these theses with statistical rigor.
                            </p>
                            <p>
                                We transform the complexity of global cycles into actionable signals, offering our partners a decisive informational edge in a saturated environment.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Team Section -->
        <section class="py-32 bg-bg-2 overflow-hidden">
            <div class="container">
                <div class="text-center mb-24 reveal">
                    <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-blue-3 mb-4 block">The People</span>
                    <h2 class="font-head text-5xl text-text tracking-tight">The Intelligence behind the research</h2>
                </div>

                <div class="flex flex-col gap-32">
                    <!-- Léo Lombardini -->
                    <div class="grid lg:grid-cols-2 gap-16 items-center">
                        <div class="relative group reveal">
                            <div class="absolute -inset-4 bg-blue-3/5 rounded-2xl blur-2xl group-hover:bg-blue-3/10 transition-colors"></div>
                            <img src="/assets/img/profil_leo_HD.jpeg" alt="Léo Lombardini" class="relative z-10 w-full aspect-[4/5] object-cover shadow-2xl transition-all duration-700" />
                            <div class="absolute bottom-8 right-8 z-20 bg-white p-6 shadow-xl hidden md:block">
                                <span class="font-mono text-xs text-blue-3 font-bold block mb-1">STRATEGY & QUANT</span>
                                <p class="text-text font-head text-lg italic">"The signal is asymmetric."</p>
                            </div>
                        </div>
                        <div class="reveal reveal-delay-1">
                            <span class="font-mono text-[0.7rem] text-blue-3 font-bold tracking-widest uppercase mb-4 block">Founder & CEO</span>
                            <h3 class="font-head text-4xl md:text-5xl text-text mb-8">Léo Lombardini</h3>
                            <div class="flex flex-col gap-6 text-lg text-off font-sans leading-relaxed">
                                <p>
                                    A trader and economics enthusiast, Léo structured Horacle Capital around one obsession: detecting macroeconomic inflection points before they are priced by the market.
                                </p>
                                <p>
                                    Passionate about market analysis and statistical modeling, he oversees the strategic allocation of the model portfolio and the development of the firm's quantitative frameworks, as well as writing weekly articles.
                                </p>
                            </div>
                            <div class="mt-10 pt-10 border-t border-border flex gap-8">
                                <div>
                                    <span class="block text-text font-bold text-2xl">EDHEC</span>
                                    <span class="text-xs font-mono uppercase text-dim">ENS D2 (Prep)</span>
                                </div>
                                <div class="w-px h-full bg-border"></div>
                                <div>
                                    <span class="block text-text font-bold text-2xl">Macro-Quant</span>
                                    <span class="text-xs font-mono uppercase text-dim">Specialization</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Raphaël Chouraqui -->
                    <div class="grid lg:grid-cols-2 gap-16 items-center">
                        <div class="order-2 lg:order-1 reveal reveal-delay-1">
                            <span class="font-mono text-[0.7rem] text-blue-3 font-bold tracking-widest uppercase mb-4 block">Research Analyst</span>
                            <h3 class="font-head text-4xl md:text-5xl text-text mb-8">Raphaël Chouraqui</h3>
                            <div class="flex flex-col gap-6 text-lg text-off font-sans leading-relaxed">
                                <p>
                                    A graduate of ESCP Business School after an ECG preparatory class, Raphaël brings rigorous analytical expertise to macro-financial research. Passionate about the dynamics of global markets, he specializes in market finance.
                                </p>
                                <p>
                                    At Horacle Capital, he decodes structural trends to transform complex economic data into coherent investment theses, combining academic depth and market pragmatism.
                                </p>
                            </div>
                            <div class="mt-10 pt-10 border-t border-border flex gap-8">
                                <div>
                                    <span class="block text-text font-bold text-2xl">ESCP</span>
                                    <span class="text-xs font-mono uppercase text-dim">ECG (Prep)</span>
                                </div>
                                <div class="w-px h-full bg-border"></div>
                                <div>
                                    <span class="block text-text font-bold text-2xl">Market Analysis</span>
                                    <span class="text-xs font-mono uppercase text-dim">Focus</span>
                                </div>
                            </div>
                        </div>
                        <div class="order-1 lg:order-2 relative group reveal">
                            <div class="absolute -inset-4 bg-blue-3/5 rounded-2xl blur-2xl group-hover:bg-blue-3/10 transition-colors"></div>
                            <img src="/assets/img/photo_profil_raphael.jpg" alt="Raphaël Chouraqui" class="relative z-10 w-full aspect-[4/5] object-cover shadow-2xl transition-all duration-700" />
                            <div class="absolute bottom-8 left-8 z-20 bg-white p-6 shadow-xl hidden md:block">
                                <span class="font-mono text-xs text-blue-3 font-bold block mb-1">ECON & FINANCE</span>
                                <p class="text-text font-head text-lg italic">"Rigor is the bedrock of alpha."</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <section class="py-32 border-t border-border bg-white">
            <div class="container max-w-6xl">
                <div class="grid lg:grid-cols-2 gap-24">
                    <div class="reveal">
                        <span class="font-mono text-[0.65rem] uppercase tracking-[0.3em] text-blue-3 mb-6 block">Inquiries</span>
                        <h2 class="font-head text-5xl text-text mb-8 tracking-tight">Let's collaborate.</h2>
                        <p class="text-lg text-off leading-relaxed mb-10 max-w-md">
                            Whether you are an institutional investor, an independent trader, or a potential partner, our direct communication channel is at your disposal.
                        </p>
                        <div class="flex flex-col gap-4 text-sm font-mono text-text">
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-px bg-blue-3"></div>
                                <span>BESPOKE RESEARCH</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-px bg-blue-3"></div>
                                <span>QUANT MODEL ACCESS</span>
                            </div>
                            <div class="flex items-center gap-3">
                                <div class="w-10 h-px bg-blue-3"></div>
                                <span>STRATEGIC PARTNERSHIPS</span>
                            </div>
                        </div>
                    </div>

                    <div class="reveal reveal-delay-1">
                        <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="bg-bg-2 p-10 shadow-sm border border-border">
                            <input type="hidden" name="access_key" value="c455f599-cf43-4be4-9835-019ffa3330db">

                            <div class="flex flex-col gap-6">
                                <div class="group">
                                    <label class="block font-mono text-[0.6rem] uppercase tracking-widest text-dim mb-2 group-focus-within:text-blue-3 transition-colors">Full Name</label>
                                    <input type="text" name="Name" required class="w-full p-4 bg-white border border-border text-text font-sans outline-none transition-all duration-300 focus:border-blue-3 focus:ring-4 focus:ring-blue-3/5">
                                </div>
                                <div class="group">
                                    <label class="block font-mono text-[0.6rem] uppercase tracking-widest text-dim mb-2 group-focus-within:text-blue-3 transition-colors">Email Address</label>
                                    <input type="email" name="Email" required class="w-full p-4 bg-white border border-border text-text font-sans outline-none transition-all duration-300 focus:border-blue-3 focus:ring-4 focus:ring-blue-3/5">
                                </div>
                                <div class="group">
                                    <label class="block font-mono text-[0.6rem] uppercase tracking-widest text-dim mb-2 group-focus-within:text-blue-3 transition-colors">Message</label>
                                    <textarea name="Message" rows="5" required class="w-full p-4 bg-white border border-border text-text font-sans resize-y outline-none transition-all duration-300 focus:border-blue-3 focus:ring-4 focus:ring-blue-3/5"></textarea>
                                </div>
                                <button type="submit" class="btn-primary border-none cursor-pointer justify-center w-full py-5 text-sm uppercase tracking-[0.2em]">Send message</button>
                            </div>
                            <p id="form-status" class="mt-6 font-mono text-center min-h-[1.2em] text-[0.7rem] uppercase tracking-widest"></p>
                        </form>
                    </div>
                </div>
            </div>
        </section>

        <div class="py-24 bg-dark">
            <div class="container">
                <SubscribeCTA
                    title="Support independent research"
                    description="Access all our macroeconomic analysis and quantitative models by becoming a premium member."
                    buttonText="Join Horacle Premium"
                />
            </div>
        </div>
    </main>

    <script is:inline>
      // Contact form script
      var form = document.getElementById("contact-form");
      if (form) {
          async function handleSubmit(event) {
            event.preventDefault();
            var status = document.getElementById("form-status");
            var button = form.querySelector("button");
            var data = new FormData(event.target);

            button.disabled = true;
            button.textContent = "Sending...";
            status.innerHTML = "";

            fetch(event.target.action, {
              method: form.method,
              body: data,
              headers: { 'Accept': 'application/json' }
            }).then(response => {
              button.disabled = false;
              button.textContent = "Send message";
              if (response.ok) {
                status.style.color = "var(--blue-2)";
                status.innerHTML = "Message sent. We will get back to you shortly.";
                form.reset();
              } else {
                response.json().then(data => {
                  status.style.color = "#DC2626";
                  if (Object.hasOwn(data, 'message')) {
                    status.innerHTML = "Error: " + data.message;
                  } else {
                    status.innerHTML = "An error occurred. Please try again.";
                  }
                })
              }
            }).catch(error => {
              button.disabled = false;
              button.textContent = "Send message";
              status.style.color = "#DC2626";
              status.innerHTML = "Connection failed. Please try again.";
            });
          }
          form.addEventListener("submit", handleSubmit);
      }
    </script>
</BaseLayout>

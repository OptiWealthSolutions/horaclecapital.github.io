---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Guide: Starting to Invest in 2026 | Horacle Academy";
const description = "Download our honest guide to taking action. ETFs, Stock Picking, DCA, and investor psychology.";
---

<BaseLayout {title} {description} activeNav="academy">
    <main class="bg-bg min-h-screen pt-24 pb-32">
        <div class="container max-w-5xl">
            
            <div class="flex flex-col lg:flex-row gap-16 items-center lg:items-start mb-24">
                <!-- Left: Visual -->
                <div class="w-full lg:w-2/5 shrink-0">
                    <div class="relative group">
                        <!-- Shadow Glow -->
                        <div class="absolute -inset-4 bg-blue-3/10 blur-2xl rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
                        
                        <!-- Ebook Cover -->
                        <div class="relative bg-dark border border-white/10 p-12 aspect-[3/4] flex flex-col justify-between shadow-2xl overflow-hidden">
                            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
                            
                            <div class="relative z-10">
                                <div class="font-mono text-blue-3 text-[0.6rem] uppercase tracking-[0.3em] font-bold mb-8">Horacle Academy</div>
                                <h1 class="font-head text-4xl text-white leading-tight mb-4">Investment.</h1>
                                <p class="text-white/60 font-sans text-sm leading-relaxed">The honest guide to taking action</p>
                            </div>

                            <div class="relative z-10">
                                <div class="h-1 w-12 bg-blue-3 mb-6"></div>
                                <div class="flex flex-wrap gap-2 text-[0.55rem] font-mono text-white/40 uppercase tracking-widest">
                                    <span>ETF</span> • <span>DCA</span> • <span>Stock Picking</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right: Content & Form -->
                <div class="flex-1">
                    <span class="inline-block px-3 py-1 bg-blue-3/10 text-blue-3 font-mono text-[0.65rem] uppercase tracking-widest font-bold mb-6">Free Resource</span>
                    <h2 class="font-head text-4xl md:text-5xl text-text mb-8 leading-tight">Escape the informational chaos.</h2>
                    
                    <div class="text-off text-lg leading-relaxed mb-10 space-y-6 font-sans">
                        <p>The internet is saturated with contradictory advice and promises of quick wealth. We wrote this guide to re-establish a simple truth: <strong>investing is a matter of method, not luck.</strong></p>
                        <p>In 40 pages, learn to build a robust portfolio tailored to your psychology, without complex jargon or dangerous shortcuts.</p>
                    </div>

                    <!-- Lead Capture Form -->
                    <div class="bg-white border border-border p-8 md:p-10 shadow-xl relative">
                        <div class="absolute top-0 left-0 w-full h-1 bg-blue-3"></div>
                        <h3 class="font-head text-xl mb-6">Receive the guide by email</h3>
                        
                        <form id="guide-form" class="space-y-4">
                            <div>
                                <label for="email" class="sr-only">Email</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    placeholder="Your professional email address..." 
                                    required
                                    class="w-full px-6 py-4 bg-bg border border-border focus:border-blue-3 focus:ring-1 focus:ring-blue-3 outline-none transition-all font-sans"
                                />
                            </div>
                            <button 
                                type="submit" 
                                id="submit-btn"
                                class="w-full bg-dark text-white font-sans font-bold py-4 uppercase tracking-[0.2em] text-xs hover:bg-blue-3 transition-colors shadow-lg"
                            >
                                Get free access
                            </button>
                            <p class="text-[0.65rem] text-dim text-center mt-4">By registering, you will also receive our weekly macro briefing. Unsubscribe in 1 click.</p>
                        </form>

                        <div id="success-msg" class="hidden text-center py-6">
                            <div class="w-12 h-12 bg-green-500/10 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                            </div>
                            <h4 class="font-head text-xl mb-2 text-text">Request registered!</h4>
                            <p class="text-off text-sm">Check your inbox in a few moments.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Preview Sections -->
            <div class="section-rule mb-12">
                <h2 class="section-label">What's in the guide</h2>
                <div class="rule-line"></div>
            </div>

            <div class="grid md:grid-cols-3 gap-10">
                <div class="space-y-4">
                    <div class="font-mono text-blue-3 text-lg font-bold">01.</div>
                    <h4 class="font-head text-xl">Profiling & Psychology</h4>
                    <p class="text-off text-sm leading-relaxed">Why the best strategy in the world is worthless if you can't stick to it during a 30% drop.</p>
                </div>
                <div class="space-y-4">
                    <div class="font-mono text-blue-3 text-lg font-bold">02.</div>
                    <h4 class="font-head text-xl">The Power of ETFs</h4>
                    <p class="text-off text-sm leading-relaxed">Understand why 90% of active managers fail and how to "buy the whole haystack" with the right indices.</p>
                </div>
                <div class="space-y-4">
                    <div class="font-mono text-blue-3 text-lg font-bold">03.</div>
                    <h4 class="font-head text-xl">DCA vs Lump Sum</h4>
                    <p class="text-off text-sm leading-relaxed">The mathematical and psychological arbitrage between investing all at once or smoothing your entries.</p>
                </div>
            </div>

            <div class="mt-24 p-12 border border-border bg-bg-2 text-center italic text-off leading-relaxed font-sans">
                "This guide is not going to promise to make you rich quickly. It's for those who want to build a sustainable competitive advantage in the markets." — Léo Lombardini
            </div>

        </div>
    </main>
</BaseLayout>

<script>
    import { supabase } from '../../../lib/supabase';

    const form = document.getElementById('guide-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const successMsg = document.getElementById('success-msg');

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const email = formData.get('email');

            submitBtn.disabled = true;
            submitBtn.textContent = "Processing...";

            try {
                const { data, error } = await supabase.functions.invoke('send-investor-guide', {
                    body: { email }
                });

                if (error) throw error;

                form.classList.add('hidden');
                successMsg?.classList.remove('hidden');
            } catch (err) {
                console.error("Error:", err);
                alert("An error occurred. Please try again.");
                submitBtn.disabled = false;
                submitBtn.textContent = "Get free access";
            }
        });
    }
</script>

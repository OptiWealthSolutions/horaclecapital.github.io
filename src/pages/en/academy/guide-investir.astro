---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, useTranslations } from '../../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (path: string) => getRelativeLocaleUrl(lang, path);

const title = "Guide: Starting to Invest in 2026 | Horacle Academy";
const description = "Download our honest guide to taking action. ETFs, Stock Picking, DCA, and investor psychology.";
---

<style>
    /* 3D Ebook CSS */
    .book-container {
        perspective: 1000px;
    }
    .book {
        width: 280px;
        height: 400px;
        position: relative;
        transform-style: preserve-3d;
        transform: rotateY(-20deg) rotateX(5deg);
        transition: transform 0.5s ease;
    }
    .book:hover {
        transform: rotateY(-10deg) rotateX(0deg);
    }
    .book-front {
        position: absolute;
        width: 280px;
        height: 400px;
        background: #0F172A;
        border: 1px solid rgba(255,255,255,0.1);
        z-index: 2;
        transform: translateZ(15px);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 30px;
        box-shadow: 10px 10px 40px rgba(0,0,0,0.5);
    }
    .book-spine {
        position: absolute;
        width: 30px;
        height: 400px;
        background: #1C2236;
        left: -15px;
        transform: rotateY(-90deg);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .book-top {
        position: absolute;
        width: 280px;
        height: 30px;
        background: #e5e7eb;
        top: -15px;
        transform: rotateX(90deg);
    }
    .book-shadow {
        position: absolute;
        width: 280px;
        height: 30px;
        background: rgba(0,0,0,0.3);
        bottom: -50px;
        filter: blur(20px);
        transform: rotateX(90deg);
    }
</style>

<BaseLayout {title} {description} activeNav="academy">
    <main class="bg-white min-h-screen">
        
        <!-- HERO SECTION (Dark) -->
        <header class="bg-dark text-white pt-24 pb-32 overflow-hidden border-b border-white/5 relative">
            <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');"></div>
            
            <nav class="container mb-20 flex justify-between items-center no-print">
                <div class="flex items-center gap-3">
                    <div class="w-8 h-8 bg-blue-600 rounded-full flex items-center justify-center text-[0.6rem] font-bold">H</div>
                    <span class="font-head text-sm tracking-widest uppercase">Horacle Academy</span>
                </div>
                <a href="#download" class="bg-blue-600 hover:bg-blue-700 text-white px-6 py-2 rounded-full text-xs font-bold uppercase tracking-widest transition-all">Download</a>
            </nav>

            <div class="container flex flex-col lg:flex-row items-center gap-20">
                <!-- Text Content -->
                <div class="flex-1 text-center lg:text-left z-10">
                    <h1 class="font-head text-5xl md:text-7xl mb-8 leading-tight tracking-tight">
                        Build a <span class="text-blue-500">strategic</span> wealth.
                    </h1>
                    <p class="text-white/60 text-lg md:text-xl mb-12 max-w-2xl font-sans leading-relaxed">
                        The honest guide to escape the market noise and take action with the rigor of an institutional investor.
                    </p>
                    
                    <div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start items-center">
                        <a href="#download" class="btn-primary px-10 py-4 shadow-2xl shadow-blue-600/30">Access the guide for free</a>
                        <div class="flex items-center gap-4 text-white/40 font-mono text-[0.6rem] uppercase tracking-widest">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
                            <span>1,500+ Downloads</span>
                        </div>
                    </div>

                    <!-- Tags -->
                    <div class="mt-16 flex flex-wrap justify-center lg:justify-start gap-8 opacity-40 grayscale">
                        <span class="text-[0.6rem] font-mono uppercase tracking-[0.2em]">ETF Strategy</span>
                        <span class="text-[0.6rem] font-mono uppercase tracking-[0.2em]">Macro Analysis</span>
                        <span class="text-[0.6rem] font-mono uppercase tracking-[0.2em]">Portfolio Design</span>
                        <span class="text-[0.6rem] font-mono uppercase tracking-[0.2em]">Risk Management</span>
                    </div>
                </div>

                <!-- 3D Book Mockup -->
                <div class="flex-shrink-0 book-container z-10 py-10 lg:py-0">
                    <div class="book">
                        <div class="book-spine"></div>
                        <div class="book-top"></div>
                        <div class="book-front">
                            <div class="z-10">
                                <img src="/assets/img/logo.png" alt="" class="w-8 h-8 mb-10 opacity-80" />
                                <div class="font-mono text-blue-500 text-[0.55rem] uppercase tracking-[0.4em] font-bold mb-4">Paper N°01</div>
                                <h2 class="font-head text-4xl text-white leading-tight mb-4">Invest-<br/>ment.</h2>
                                <p class="text-white/40 font-sans text-xs leading-relaxed">Honest guide to taking action.</p>
                            </div>
                            <div class="z-10">
                                <div class="h-1 w-10 bg-blue-600 mb-6"></div>
                                <span class="text-[0.55rem] font-mono text-white/30 uppercase tracking-[0.2em]">Horacle Academy</span>
                            </div>
                            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
                        </div>
                        <div class="book-shadow"></div>
                    </div>
                </div>
            </div>
        </header>

        <!-- FOR WHOM SECTION -->
        <section class="py-32 bg-white">
            <div class="container">
                <div class="text-center mb-20">
                    <span class="text-blue-600 font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-4 block">Target Profiling</span>
                    <h2 class="font-head text-4xl text-dark mb-6">Who is this guide for?</h2>
                    <p class="text-slate-500 max-w-2xl mx-auto font-sans">
                        We didn't write this guide for everyone. It's designed for those who value method over luck.
                    </p>
                </div>

                <div class="grid md:grid-cols-3 gap-12">
                    <div class="p-10 border border-slate-100 bg-slate-50/50 hover:border-blue-600 transition-all group">
                        <div class="w-10 h-10 bg-blue-600 text-white flex items-center justify-center mb-8">01</div>
                        <h3 class="font-head text-2xl text-dark mb-4 tracking-tight">The Beginner</h3>
                        <p class="text-slate-600 text-sm leading-relaxed font-sans font-light">
                            You know you should invest but the information overload paralyzes you. We set your foundations.
                        </p>
                    </div>
                    <div class="p-10 border border-slate-100 bg-slate-50/50 hover:border-blue-600 transition-all group">
                        <div class="w-10 h-10 bg-blue-600 text-white flex items-center justify-center mb-8">02</div>
                        <h3 class="font-head text-2xl text-dark mb-4 tracking-tight">The Intermediate</h3>
                        <p class="text-slate-600 text-sm leading-relaxed font-sans font-light">
                            You already have an account but no clear strategy. We structure your allocation and risk management.
                        </p>
                    </div>
                    <div class="p-10 border border-slate-100 bg-slate-50/50 hover:border-blue-600 transition-all group">
                        <div class="w-10 h-10 bg-blue-600 text-white flex items-center justify-center mb-8">03</div>
                        <h3 class="font-head text-2xl text-dark mb-4 tracking-tight">The Advanced</h3>
                        <p class="text-slate-600 text-sm leading-relaxed font-sans font-light">
                            You want to challenge your convictions against an institutional macro vision and optimize your fees.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- AUTHOR NOTE SECTION -->
        <section class="py-32 bg-slate-50 border-y border-slate-100">
            <div class="container max-w-5xl">
                <div class="flex flex-col lg:flex-row gap-16 items-center">
                    <div class="w-48 h-48 lg:w-64 lg:h-64 rounded-full overflow-hidden border-4 border-white shadow-xl flex-shrink-0 grayscale hover:grayscale-0 transition-all duration-500">
                        <img src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?auto=format&fit=crop&w=400&q=80" alt="Léo Lombardini" class="w-full h-full object-cover" />
                    </div>
                    <div class="flex-1 text-center lg:text-left">
                        <span class="text-blue-600 font-mono text-[0.6rem] uppercase tracking-[0.3em] font-bold mb-4 block">Note from the author</span>
                        <h3 class="font-head text-3xl text-dark mb-8 italic">"This guide is not going to promise to make you rich quickly..."</h3>
                        <div class="space-y-6 text-slate-600 font-sans font-light leading-relaxed text-lg">
                            <p>I am not one of those internet "influ-thieves". This guide was hand-written, with a real opinion, not a Wikipedia compilation.</p>
                            <p>Dozens of people have asked me the same question: "I know I should invest. But I don't know how, or when, or in what."</p>
                        </div>
                        <div class="mt-10">
                            <p class="text-dark font-bold uppercase tracking-widest text-xs">Léo Lombardini</p>
                            <p class="text-blue-600 text-[0.65rem] uppercase tracking-widest mt-1">Founder @ Horacle Capital</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- CURRICULUM PREVIEW -->
        <section class="py-32">
            <div class="container">
                <div class="section-rule mb-20">
                    <h2 class="section-label text-dark uppercase tracking-[0.3em] text-xs">What's in the guide</h2>
                    <div class="rule-line border-slate-200"></div>
                </div>

                <div class="max-w-4xl mx-auto space-y-12">
                    <div class="flex flex-col md:flex-row gap-10 items-center group">
                        <div class="w-full md:w-1/3 aspect-[4/3] bg-dark relative overflow-hidden border border-white/5 flex items-center justify-center p-8">
                            <div class="text-blue-500 font-head text-5xl opacity-20 absolute -top-4 -left-4">01</div>
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-head text-2xl text-dark mb-4 group-hover:text-blue-600 transition-colors">Investor Psychology</h4>
                            <p class="text-slate-500 font-sans font-light leading-relaxed">Learn to handle 30% drops without panicking. Discover why the average investor is their own worst enemy and how to defeat your cognitive biases.</p>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row-reverse gap-10 items-center group">
                        <div class="w-full md:w-1/3 aspect-[4/3] bg-dark relative overflow-hidden border border-white/5 flex items-center justify-center p-8">
                            <div class="text-blue-500 font-head text-5xl opacity-20 absolute -top-4 -right-4 text-right">02</div>
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M16 12l-4-4-4 4M12 16V9"/></svg>
                        </div>
                        <div class="flex-1 text-right md:text-left">
                            <h4 class="font-head text-2xl text-dark mb-4 group-hover:text-blue-600 transition-colors">The ETF & Stocks Engine</h4>
                            <p class="text-slate-500 font-sans font-light leading-relaxed">90% of active managers fail. We explain how to "buy the haystack" with the right ETFs and when Stock Picking becomes a strategic weapon again.</p>
                        </div>
                    </div>

                    <div class="flex flex-col md:flex-row gap-10 items-center group">
                        <div class="w-full md:w-1/3 aspect-[4/3] bg-dark relative overflow-hidden border border-white/5 flex items-center justify-center p-8">
                            <div class="text-blue-500 font-head text-5xl opacity-20 absolute -top-4 -left-4">03</div>
                            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#2563EB" stroke-width="1.5"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                        </div>
                        <div class="flex-1">
                            <h4 class="font-head text-2xl text-dark mb-4 group-hover:text-blue-600 transition-colors">DCA, Lump Sum & Allocation</h4>
                            <p class="text-slate-500 font-sans font-light leading-relaxed">Discover the mathematical arbitrage between investing massively or gradually. We detail typical allocations (Defensive, Moderate, Dynamic).</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- DOWNLOAD FORM SECTION -->
        <section id="download" class="py-32 bg-dark text-white relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
            <div class="container max-w-3xl relative z-10">
                <div class="bg-white text-dark p-12 md:p-20 shadow-2xl relative">
                    <div class="absolute top-0 left-0 w-full h-2 bg-blue-600"></div>
                    <div class="text-center mb-12">
                        <h2 class="font-head text-4xl mb-4">Download the Free Guide</h2>
                        <p class="text-slate-500 font-sans text-sm">The PDF will be sent immediately to your email address.</p>
                    </div>

                    <form id="guide-form-final" class="space-y-6">
                        <div>
                            <label for="email-final" class="sr-only">Email</label>
                            <input 
                                type="email" 
                                id="email-final" 
                                name="email" 
                                placeholder="your@email.com" 
                                required
                                class="w-full px-8 py-5 bg-slate-50 border border-slate-200 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none transition-all font-sans text-lg text-center"
                            />
                        </div>
                        <button 
                            type="submit" 
                            id="submit-btn-final"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-sans font-bold py-5 uppercase tracking-[0.2em] text-sm shadow-xl transition-all"
                        >
                            Get my instant access
                        </button>
                    </form>

                    <div id="success-msg-final" class="hidden text-center py-10">
                        <div class="w-16 h-16 bg-green-50 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <h4 class="font-head text-3xl mb-2 text-dark">Request confirmed</h4>
                        <p class="text-slate-700">Check your inbox in a few seconds.</p>
                    </div>
                </div>
                
                <p class="text-center text-white/30 text-[0.6rem] mt-12 uppercase tracking-[0.2em] font-mono italic">
                    Horacle Academy — Strategic Mentoring for Demanding Investors
                </p>
            </div>
        </section>

    </main>
</BaseLayout>

<script>
    import { supabase } from '../../../lib/supabase';

    const setupForm = (formId, btnId, successId) => {
        const form = document.getElementById(formId) as HTMLFormElement;
        const submitBtn = document.getElementById(btnId) as HTMLButtonElement;
        const successMsg = document.getElementById(successId);

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(form);
                const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;
                const email = emailInput?.value;

                submitBtn.disabled = true;
                submitBtn.textContent = "Loading...";

                try {
                    const { data, error } = await supabase.functions.invoke('send-investor-guide', {
                        body: { email }
                    });

                    if (error) throw error;

                    form.classList.add('hidden');
                    successMsg?.classList.remove('hidden');
                    successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } catch (err) {
                    console.error("Error:", err);
                    alert("An error occurred. Please try again.");
                    submitBtn.disabled = false;
                    submitBtn.textContent = "Retry";
                }
            });
        }
    };

    setupForm('guide-form', 'submit-btn', 'success-msg');
    setupForm('guide-form-final', 'submit-btn-final', 'success-msg-final');
</script>

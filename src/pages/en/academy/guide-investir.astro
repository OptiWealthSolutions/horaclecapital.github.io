---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const title = "Guide: Starting to Invest in 2026 | Horacle Academy";
const description = "Download our honest guide to taking action. ETFs, Stock Picking, DCA, and investor psychology.";
---

<BaseLayout {title} {description} activeNav="academy">
    <main class="bg-[#F8FAFC] min-h-screen">
        <!-- Schema.org for SEO -->
        <script type="application/ld+json" set:html={JSON.stringify({
            "@context": "https://schema.org",
            "@type": "WebPage",
            "name": "Investing Guide 2026",
            "description": "A comprehensive guide on ETFs, DCA, and portfolio management.",
            "publisher": {
                "@type": "Organization",
                "name": "Horacle Capital"
            }
        })} />

        <!-- Persistent Trust Bar -->
        <div class="bg-dark py-3 border-b border-white/5 no-print" aria-hidden="true">
            <div class="container flex justify-center items-center gap-8 text-[0.6rem] font-mono text-white/40 uppercase tracking-[0.2em]">
                <span class="flex items-center gap-2"><span class="w-1 h-1 bg-blue-500 rounded-full"></span> 40+ Strategy Pages</span>
                <span class="hidden md:flex items-center gap-2"><span class="w-1 h-1 bg-blue-500 rounded-full"></span> 0% Marketing Jargon</span>
                <span class="flex items-center gap-2"><span class="w-1 h-1 bg-blue-500 rounded-full"></span> Updated June 2026</span>
            </div>
        </div>

        <div class="container max-w-6xl pt-16 md:pt-24 pb-32">
            
            <!-- Hero Section -->
            <section class="flex flex-col lg:flex-row gap-16 lg:items-center mb-32" aria-labelledby="hero-title">
                <div class="flex-1 order-2 lg:order-1">
                    <span class="inline-block px-3 py-1 bg-blue-600 text-white font-mono text-[0.65rem] uppercase tracking-widest font-bold mb-8">Strategic Resource</span>
                    <h1 id="hero-title" class="font-head text-5xl md:text-7xl text-dark mb-8 leading-[1.05] tracking-tight">
                        Investing is not a <span class="text-blue-600 italic">game.</span>
                    </h1>
                    <p class="text-slate-700 text-xl md:text-2xl leading-relaxed mb-10 font-sans font-light max-w-2xl">
                        Facing the noise of social media, we have extracted the <strong class="text-dark font-semibold">institutional signal</strong> to help you build a robust and durable portfolio.
                    </p>

                    <!-- Lead Capture -->
                    <div class="bg-white border border-slate-200 p-8 md:p-10 shadow-2xl shadow-slate-200/50 relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1.5 bg-blue-600"></div>
                        <h2 class="font-head text-2xl mb-2 text-dark">Download the Free Guide</h2>
                        <p class="text-slate-600 text-sm mb-8 font-sans">Join 1,500+ savvy investors. Immediate delivery by email.</p>
                        
                        <form id="guide-form" class="flex flex-col md:flex-row gap-4" aria-label="Guide subscription">
                            <div class="flex-1">
                                <label for="email" class="sr-only">Your professional email address</label>
                                <input 
                                    type="email" 
                                    id="email" 
                                    name="email" 
                                    placeholder="Email..." 
                                    required
                                    class="w-full px-6 py-4 bg-slate-50 border border-slate-200 focus:border-blue-600 focus:bg-white outline-none transition-all font-sans text-dark"
                                />
                            </div>
                            <button 
                                type="submit" 
                                id="submit-btn"
                                class="bg-blue-600 text-white font-sans font-bold px-10 py-4 uppercase tracking-[0.1em] text-xs hover:bg-dark transition-all"
                            >
                                Get Access
                            </button>
                        </form>
                        <p class="text-[0.65rem] text-slate-500 mt-4 font-sans italic">By validating, you agree to receive our weekly briefing (unsubscribe in 1 click).</p>

                        <div id="success-msg" class="hidden text-center py-10" role="alert">
                            <div class="w-16 h-16 bg-green-50 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
                                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                            </div>
                            <h4 class="font-head text-3xl mb-2 text-dark">Request Confirmed</h4>
                            <p class="text-slate-700">The guide is being sent to your inbox.</p>
                        </div>
                    </div>
                </div>

                <!-- Visual: Ebook Mockup -->
                <div class="w-full lg:w-2/5 order-1 lg:order-2" aria-hidden="true">
                    <div class="relative">
                        <div class="absolute -inset-10 bg-blue-600/5 rounded-full blur-3xl"></div>
                        <div class="relative bg-dark border border-white/10 p-12 aspect-[3/4.2] flex flex-col justify-between shadow-2xl transform lg:rotate-2">
                            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
                            <div class="relative z-10">
                                <img src="/assets/img/logo.png" alt="Horacle" class="w-10 h-10 mb-12 opacity-80" />
                                <div class="font-mono text-blue-400 text-[0.6rem] uppercase tracking-[0.4em] font-bold mb-6">2026 GUIDE</div>
                                <h2 class="font-head text-5xl text-white leading-tight mb-6">Invest-<br/>ment.</h2>
                                <p class="text-white/50 font-sans text-sm leading-relaxed">The honest method.</p>
                            </div>
                            <div class="relative z-10">
                                <div class="h-1 w-12 bg-blue-600 mb-8"></div>
                                <span class="text-[0.6rem] font-mono text-white/30 uppercase tracking-[0.2em]">Horacle Academy</span>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Comparison Table -->
            <section class="mb-32">
                <div class="section-rule mb-12">
                    <h2 class="section-label text-dark">Escape the market noise</h2>
                    <div class="rule-line border-slate-200"></div>
                </div>

                <div class="grid md:grid-cols-2 gap-px bg-slate-200 border border-slate-200">
                    <div class="bg-white p-12">
                        <h3 class="font-head text-lg text-slate-400 mb-8 uppercase tracking-widest flex items-center gap-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-slate-300"><path d="M18 6L6 18M6 6l12 12"/></svg>
                            The Noise (Web)
                        </h3>
                        <ul class="space-y-6">
                            <li class="text-slate-600 text-sm flex gap-3"><span class="text-slate-300">•</span> Illusory and quick financial freedom.</li>
                            <li class="text-slate-600 text-sm flex gap-3"><span class="text-slate-300">•</span> Opaque and overpriced courses.</li>
                            <li class="text-slate-600 text-sm flex gap-3"><span class="text-slate-300">•</span> Copied strategies without real foundation.</li>
                        </ul>
                    </div>
                    <div class="bg-dark p-12">
                        <h3 class="font-head text-lg text-blue-400 mb-8 uppercase tracking-widest flex items-center gap-3">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="text-blue-500"><polyline points="20 6 9 17 4 12"/></svg>
                            The Signal (Horacle)
                        </h3>
                        <ul class="space-y-6">
                            <li class="text-white/80 text-sm flex gap-3"><span class="text-blue-600">•</span> Analysis of macro liquidity cycles.</li>
                            <li class="text-white/80 text-sm flex gap-3"><span class="text-blue-600">•</span> Simple method: ETFs, DCA, and Rigor.</li>
                            <li class="text-white/80 text-sm flex gap-3"><span class="text-blue-600">•</span> Independent expert opinion.</li>
                        </ul>
                    </div>
                </div>
            </section>

            <!-- Key Topics -->
            <section class="grid md:grid-cols-3 gap-12 mb-32" aria-label="Guide content">
                <div>
                    <div class="w-10 h-10 bg-white border border-slate-200 flex items-center justify-center mb-6">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-dark"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                    </div>
                    <h3 class="font-head text-xl text-dark mb-4">Psychology & Bias</h3>
                    <p class="text-slate-700 text-sm leading-relaxed">How not to panic during a 30% crash and stay focused on the objective.</p>
                </div>
                <div>
                    <div class="w-10 h-10 bg-white border border-slate-200 flex items-center justify-center mb-6">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-dark"><circle cx="12" cy="12" r="10"/><path d="M16 12l-4-4-4 4M12 16V9"/></svg>
                    </div>
                    <h3 class="font-head text-xl text-dark mb-4">ETF Engine</h3>
                    <p class="text-slate-700 text-sm leading-relaxed">The indices to prioritize for long-term performance with minimal fees.</p>
                </div>
                <div>
                    <div class="w-10 h-10 bg-white border border-slate-200 flex items-center justify-center mb-6">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-dark"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
                    </div>
                    <h3 class="font-head text-xl text-dark mb-4">DCA Allocation</h3>
                    <p class="text-slate-700 text-sm leading-relaxed">Should you invest right away or smooth your entries? The definitive mathematical arbitrage.</p>
                </div>
            </section>

            <!-- Final CTA -->
            <section class="bg-dark p-12 md:p-20 text-center relative overflow-hidden">
                <div class="relative z-10">
                    <h2 class="font-head text-4xl md:text-5xl text-white mb-10 max-w-2xl mx-auto leading-tight">Ready to build your strategy?</h2>
                    <a href="#guide-form" class="btn-primary px-12 py-5 text-sm uppercase tracking-widest bg-blue-600 hover:bg-blue-700 transition-colors">Get my free access</a>
                </div>
            </section>

        </div>
    </main>
</BaseLayout>

<script>
    import { supabase } from '../../../lib/supabase';

    const form = document.getElementById('guide-form') as HTMLFormElement;
    const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
    const successMsg = document.getElementById('success-msg');
    const formContent = form?.parentElement;

    if (form) {
        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(form);
            const email = formData.get('email');

            submitBtn.disabled = true;
            submitBtn.textContent = "Processing...";

            try {
                const { data, error } = await supabase.functions.invoke('send-investor-guide', {
                    body: { email }
                });

                if (error) throw error;

                form.classList.add('hidden');
                if (formContent) {
                   const title = formContent.querySelector('h3');
                   const desc = formContent.querySelector('p');
                   if (title) title.classList.add('hidden');
                   if (desc) desc.classList.add('hidden');
                }
                successMsg?.classList.remove('hidden');
                
                // Scroll to success message
                successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
            } catch (err) {
                console.error("Error:", err);
                alert("An error occurred. Please try again.");
                submitBtn.disabled = false;
                submitBtn.textContent = "Download the Guide";
            }
        });
    }
</script>

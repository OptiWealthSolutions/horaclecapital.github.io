---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Horacle Capital Newsletter | Macro Watch & Quantitative Signals';
const description = "Join more than 1,000 investors and receive our weekly analysis on liquidity cycles, central banks, and our market theses.";
---

<BaseLayout {title} {description}>
    <header class="page-header relative h-[50vh] flex items-center justify-center overflow-hidden">
      <img src="/assets/img/banner.jpg" alt="Horacle Capital Newsletter" class="header-bg scale-110" aria-hidden="true" />
      <div class="absolute inset-0 bg-dark/60 backdrop-blur-[2px]"></div>
      <div class="relative z-10 text-center px-6">
        <span class="font-mono text-[0.7rem] uppercase tracking-[0.4em] text-blue-3 mb-4 block reveal">Strategic Intelligence</span>
        <h1 class="text-5xl md:text-7xl lg:text-8xl font-head text-white mb-6 tracking-tight reveal reveal-delay-1">The Note</h1>
        <p class="text-lg md:text-xl text-white/80 font-light max-w-2xl mx-auto leading-relaxed reveal reveal-delay-2">Every Monday, the pure signal extracted from market complexity.</p>
      </div>
    </header>

    <main class="bg-white">
        <section class="py-24 md:py-32">
            <div class="container max-w-6xl">
                <div class="grid lg:grid-cols-2 gap-20 items-center">
                    <!-- Left: Social Proof & Benefits -->
                    <div class="reveal">
                        <h2 class="font-head text-4xl md:text-5xl text-text mb-8 leading-tight">Stop enduring the markets. <br/><span class="text-blue-2">Anticipate them.</span></h2>

                        <div class="space-y-8">
                            <div class="flex gap-6">
                                <div class="w-12 h-12 flex-shrink-0 bg-blue-3/10 flex items-center justify-center rounded-full">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue-3)" stroke-width="2"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
                                </div>
                                <div>
                                    <h3 class="font-head text-xl text-text mb-2">Global Macro Watch</h3>
                                    <p class="text-off leading-relaxed">Decoding liquidity cycles and monetary policies before they make the headlines.</p>
                                </div>
                            </div>

                            <div class="flex gap-6">
                                <div class="w-12 h-12 flex-shrink-0 bg-blue-3/10 flex items-center justify-center rounded-full">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue-3)" stroke-width="2"><path d="M12 2v20M2 12h20M12 2l10 10-10 10L2 12z"/></svg>
                                </div>
                                <div>
                                    <h3 class="font-head text-xl text-text mb-2">Quantitative Signals</h3>
                                    <p class="text-off leading-relaxed">Exclusive access to our scoring and volatility models to validate your theses.</p>
                                </div>
                            </div>

                            <div class="flex gap-6">
                                <div class="w-12 h-12 flex-shrink-0 bg-blue-3/10 flex items-center justify-center rounded-full">
                                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--blue-3)" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                                </div>
                                <div>
                                    <h3 class="font-head text-xl text-text mb-2">Zero Noise</h3>
                                    <p class="text-off leading-relaxed">No advertising, no spam. Only actionable, high-value research.</p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-12 p-8 bg-bg-2 border border-border italic text-off text-sm leading-relaxed">
                            "Essential reading to understand global capital flows. Horacle Capital's rigor is exceptional."
                        </div>
                    </div>

                    <!-- Right: Form -->
                    <div class="reveal reveal-delay-1">
                        <div class="bg-dark p-10 md:p-16 shadow-2xl relative overflow-hidden">
                            <div class="absolute top-0 right-0 w-64 h-64 bg-blue-3/5 blur-[100px] rounded-full"></div>

                            <h3 class="font-head text-3xl text-white mb-6 relative z-10">Join the list</h3>
                            <p class="text-white/60 mb-10 relative z-10 leading-relaxed">Sign up for free to receive the next weekly note directly in your terminal.</p>

                            <form id="api-newsletter-form" action="https://fcfd001f.sibforms.com/serve/MUIFAMsHK_ThjVdJrUwMK-YVva9D-V6Sy5_qwv9w7R-BSFNofF9FNnLIyHrejN60zuHn5ieeNlyQVcktmVWsY-2KSC0nROM37etiiX9ed1ETcuRNeIhUyctsmaKrhiHSvrzJtm_m8HdQ1S02yREYcYi1T6MdyApQ7JoRB9uQGp5pxRVZJ5dQVG0mKqPhTYnuL3OM9bVMjFyWNwReeg==" method="POST" class="relative z-10">
                                <div class="flex flex-col gap-6">
                                    <div class="group">
                                        <label class="block font-mono text-[0.6rem] uppercase tracking-widest text-white/40 mb-2 group-focus-within:text-blue-3 transition-colors">Your email address</label>
                                        <input type="email" name="EMAIL" placeholder="your@email.com" required
                                               class="w-full p-4 bg-white/5 border border-white/10 text-white font-mono outline-none transition-all duration-300 focus:border-blue-3 focus:bg-white/10">
                                    </div>
                                    <button type="submit" class="btn-primary border-none cursor-pointer justify-center w-full py-5 text-sm uppercase tracking-[0.2em]">
                                        Join the watch
                                    </button>
                                </div>
                                <p id="subscription-status" class="mt-6 font-mono text-center min-h-[1.2em] text-[0.7rem] uppercase tracking-widest text-white/40"></p>
                            </form>

                            <p class="mt-10 text-[0.65rem] text-white/20 text-center font-mono uppercase tracking-widest">
                                100% Research — Unsubscribe in 1 click
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Past Issues Preview -->
        <section class="py-24 bg-bg-2 border-t border-border">
            <div class="container text-center">
                <span class="font-mono text-[0.6rem] uppercase tracking-[0.4em] text-blue-3 mb-6 block">Archives</span>
                <h2 class="font-head text-4xl text-text mb-12">They received these analyses</h2>

                <div class="grid md:grid-cols-3 gap-8 max-w-5xl mx-auto">
                    <div class="bg-white p-8 border border-border shadow-sm text-left">
                        <span class="text-xs font-mono text-dim mb-4 block">Note N°12</span>
                        <h4 class="font-head text-xl mb-3">All Hawkish?</h4>
                        <p class="text-off text-sm">Analysis of the Fed/ECB monetary divergence and its impact on G7 FX.</p>
                    </div>
                    <div class="bg-white p-8 border border-border shadow-sm text-left">
                        <span class="text-xs font-mono text-dim mb-4 block">Note N°11</span>
                        <h4 class="font-head text-xl mb-3">Dollar Under Strain</h4>
                        <p class="text-off text-sm">The rise in US long-term yields and the resilience of the Japanese Yen.</p>
                    </div>
                    <div class="bg-white p-8 border border-border shadow-sm text-left">
                        <span class="text-xs font-mono text-dim mb-4 block">Note N°10</span>
                        <h4 class="font-head text-xl mb-3">Stagflation Expected</h4>
                        <p class="text-off text-sm">Anticipating inflection points on EU equity markets.</p>
                    </div>
                </div>
            </div>
        </section>
    </main>
</BaseLayout>

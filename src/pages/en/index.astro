---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import MacroFAQ from '../../components/MacroFAQ.astro';
import SubscribeCTA from '../../components/SubscribeCTA.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getRelativeLocaleUrl } from 'astro:i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const l = (path: string) => getRelativeLocaleUrl(lang, path);

const allRapports = await getCollection('rapports', ({ data }) => !data.draft && (data.lang ?? 'fr') === 'en');
const sortedRapports = allRapports.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latestFX = sortedRapports.find(r => r.data.category === 'FX & Macro');
const latestCommo = sortedRapports.find(r => r.data.category === 'Commodities & Stocks');
const latestCoupDoeil = sortedRapports.find(r => r.data.category === "Le Coup d'Oeil");

const isNewReport = (date: string) => {
  const today = new Date();
  const reportDate = new Date(date);
  const diffTime = Math.abs(today.getTime() - reportDate.getTime());
  const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
  return diffDays <= 7;
};

let latestReports = [latestFX, latestCommo, latestCoupDoeil].filter(Boolean);

// S'il manque des articles (ex: pas encore d'article Commodities), on complète avec les plus récents
if (latestReports.length < 3) {
  const existingSlugs = latestReports.map(r => r.slug);
  const remaining = sortedRapports.filter(r => !existingSlugs.includes(r.slug));
  const needed = 3 - latestReports.length;
  latestReports = [...latestReports, ...remaining.slice(0, needed)];
}

const title = t('home.hero.title');
const description = "Horacle Capital : Recherche indépendante en macroéconomie et finance quantitative. Analyses hebdomadaires, modèles de scoring et mentorat stratégique pour investisseurs.";
---

<BaseLayout {title} {description} activeNav="home">
    <header class="hero hero-index text-center flex flex-col items-center justify-center min-h-screen min-h-[100dvh] bg-dark relative overflow-hidden border-b border-border-dk !py-0">
      <h1 class="sr-only">{t('home.hero.title')}</h1>
      
      <!-- Impeccable Aesthetic Background -->
      <div class="absolute inset-0 pointer-events-none z-0">
        <!-- Subtle Grid -->
        <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(255,255,255,1) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,1) 1px, transparent 1px); background-size: 40px 40px;"></div>
        <!-- Soft glowing radial gradients -->
        <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[800px] h-[400px] bg-blue-3/10 blur-[120px] rounded-[100%]"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-blue-2/5 blur-[100px] rounded-full"></div>
      </div>

      <div class="hero-inner flex flex-col items-center justify-center relative z-10 w-full px-6">
        <div class="flex flex-col items-center justify-center w-full max-w-5xl mx-auto">
          
          <div class="mb-10 relative reveal">
            <img src="/assets/img/logo_ban.svg" alt="HORACLE CAPITAL" class="w-full max-w-[320px] md:max-w-[550px] lg:max-w-[750px] min-[1500px]:max-w-[900px] drop-shadow-2xl brightness-0 invert" />
          </div>
          
          <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6 w-full px-4 sm:px-0 reveal reveal-delay-1">
            <a href={l("/reports")} class="btn-primary w-full sm:w-auto justify-center text-sm md:text-base px-5 md:px-7 py-3 md:py-3.5 shadow-xl hover:shadow-blue-3/20 flex items-center gap-3">
              {t('home.hero.reportsBtn')}
              <svg width="18" height="18" viewBox="0 0 14 14" fill="none" class="w-4 h-4 md:w-5 md:h-5"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
            <a href={l("/research")} class="w-full sm:w-auto justify-center text-sm md:text-base px-5 md:px-7 py-3 md:py-3.5 shadow-xl flex items-center gap-3 border border-white/20 text-white hover:bg-white/5 transition-colors font-bold font-sans tracking-wide">
              {t('home.hero.researchBtn')}
              <svg width="18" height="18" viewBox="0 0 14 14" fill="none" class="w-4 h-4 md:w-5 md:h-5"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </div>

          <p class="hero-sub hidden md:flex items-center justify-center gap-4 text-xs md:text-sm lg:text-base mt-16 font-mono text-white/40 tracking-[0.2em] uppercase reveal reveal-delay-2">
            <span>{t('home.hero.tag1')}</span>
            <span class="w-1 h-1 rounded-full bg-blue-3"></span>
            <span>{t('home.hero.tag2')}</span>
            <span class="w-1 h-1 rounded-full bg-blue-3"></span>
            <span>{t('home.hero.tag3')}</span>
          </p>
          
        </div>
      </div>
    </header>

    <main>
      <!-- DERNIÈRES PUBLICATIONS -->
      <section class="py-12 border-t border-border bg-white">
        <div class="container">
          <div class="section-rule mb-12">
            <h2 class="section-label">{t('home.latest.title')}</h2>
            <div class="rule-line"></div>
            <a href={l("/reports")} class="rule-link">{t('home.latest.viewAll')} <span>→</span></a>
          </div>

          <div class="grid lg:grid-cols-3 gap-6 lg:gap-8">
            {latestReports.map((rapport, index) => (
              <a href={l(`/reports/${rapport.slug.replace(/^en\//, '')}`)} class={`reveal reveal-delay-${index} group relative flex flex-col bg-white border border-border hover:border-blue-3 transition-colors shadow-sm hover:shadow-md overflow-hidden`}>
                <div class="absolute top-0 left-0 w-full h-1 bg-blue-3 scale-x-0 group-hover:scale-x-100 transition-transform origin-left z-10"></div>
                <div class="h-32 md:h-48 overflow-hidden border-b border-border relative">
                  <img src={rapport.data.thumbnail || '/assets/img/banner.jpg'} alt={rapport.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" onerror="this.src='/assets/img/banner.jpg'" />
                  <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
                  <div class="absolute top-4 left-4 flex gap-2">
                    <span class="bg-blue-3 text-white font-sans text-[0.58rem] uppercase tracking-[0.1em] px-3 py-1 font-bold rounded-none shadow-md">{rapport.data.category}</span>
                  </div>
                  {isNewReport(rapport.data.date) && (
                    <div class="absolute top-4 right-4 z-20">
                      <span class="bg-blue-2 text-white font-sans text-[0.6rem] uppercase tracking-[0.2em] px-3 py-1 font-bold shadow-xl border border-white/10">New</span>
                    </div>
                  )}
                </div>
                <div class="p-5 md:p-8 flex flex-col flex-1">
                  <div class="font-sans text-[0.55rem] md:text-[0.6rem] text-dim mb-2 md:mb-3 uppercase tracking-widest">{new Date(rapport.data.date).toLocaleDateString(lang === 'fr' ? 'fr-FR' : 'en-US', { day: '2-digit', month: 'short', year: 'numeric' })}</div>
                  <h3 class="font-head text-lg md:text-2xl font-semibold text-text mb-3 md:mb-4 leading-tight group-hover:text-blue-3 transition-colors line-clamp-2">{rapport.data.title}</h3>
                  <p class="text-off text-xs md:text-[0.9rem] leading-relaxed line-clamp-2 md:line-clamp-3 mb-4 md:mb-6 flex-1 font-sans">{rapport.data.description}</p>
                  <div class="inline-flex items-center gap-2 font-sans text-[0.65rem] md:text-[0.75rem] font-bold text-text mt-auto pt-4 md:pt-6 border-t border-border/50 group-hover:text-blue-3 transition-colors">
                    {t('home.latest.readMore')} <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA BEGINNER GUIDE -->
      <section class="py-12 bg-dark relative overflow-hidden group border-y border-white/5">
        <div class="absolute inset-0 opacity-[0.03] grayscale pointer-events-none" style="background-image: url('https://www.transparenttextures.com/patterns/carbon-fibre.png');"></div>
        <div class="container relative z-10">
          <div class="flex flex-col md:flex-row items-center justify-between gap-10">
            <div class="text-center md:text-left">
              <span class="font-mono text-blue-3 text-[0.65rem] uppercase tracking-[0.2em] font-bold mb-4 block">Free Resource</span>
              <h2 class="font-head text-3xl md:text-4xl text-white mb-4">Start Investing in 2026</h2>
              <p class="text-white/60 text-base md:text-lg max-w-xl font-sans font-light">Learn the basics of macroeconomics and portfolio management with our exclusive beginner's guide.</p>
            </div>
            <div class="shrink-0">
              <a href={l("/academy/guide-investir")} class="btn-primary px-8 py-4 shadow-2xl shadow-blue-3/20">
                Access the Guide
                <svg width="18" height="18" viewBox="0 0 14 14" fill="none" class="ml-2"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </a>
            </div>
          </div>
        </div>
      </section>

      <!-- ÉCOSYSTÈME ASYMÉTRIQUE -->
      <section class="py-12 border-t border-border" style="background:var(--bg-2);">
        <div class="container">
          <div class="section-rule mb-12">
            <h2 class="section-label">{t('home.eco.title')}</h2>
            <div class="rule-line"></div>
          </div>

          <div class="eco-grid">
            <!-- Portfolio (Replaces Academy) -->
            <a href={l("/portfolio")} class="eco-card academy reveal">
              <div class="eco-image-bg" style="background-image: url('https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=1200&q=80');"></div>
              <span class="eco-label">{t('home.eco.portfolio.label')}</span>
              <h3 class="eco-title">{t('home.eco.portfolio.title')}</h3>
              <p class="eco-desc">{t('home.eco.portfolio.desc')}</p>
              <span class="eco-link">{t('home.eco.portfolio.link')} <span>→</span></span>
            </a>

            <!-- Research -->
            <a href={l("/research")} class="eco-card featured dark reveal reveal-delay-1">
              <div class="eco-image-bg" style="background-image: url('/assets/img/notebook_banner.jpg');"></div>
              <span class="eco-label">{t('home.eco.research.label')}</span>
              <h3 class="eco-title">{t('home.eco.research.title')}</h3>
              <p class="eco-desc">{t('home.eco.research.desc')}</p>
              <span class="eco-link">{t('home.eco.research.link')} <span>→</span></span>
            </a>

            <!-- Reports -->
            <a href={l("/reports")} class="eco-card mission reveal reveal-delay-2">
              <span class="eco-label">{t('home.eco.reports.label')}</span>
              <h3 class="eco-title">{t('home.eco.reports.title')}</h3>
              <p class="eco-desc">{t('home.eco.reports.desc')}</p>
              <span class="eco-link">{t('home.eco.reports.link')} <span>→</span></span>
            </a>
          </div>
        </div>
      </section>

      <!-- WHO WE ARE : PHILOSOPHY -->
      <section id="about" class="py-32 bg-dark relative border-y border-white/10 overflow-hidden">
        <div class="container relative z-10">
          <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-center">
            <!-- Left Column: Text -->
            <div class="reveal">
              <span class="font-mono text-[0.65rem] uppercase tracking-[0.4em] text-blue-3 mb-6 block">The Philosophy</span>
              <h2 class="font-head text-5xl md:text-7xl text-white mb-8 leading-[1.05] tracking-tight">Horacle Capital</h2>
              <div class="w-16 h-1 bg-blue-3 mb-10"></div>

              <p class="text-xl text-white/90 leading-relaxed font-light mb-8 max-w-lg">
                We are not a media outlet. We are an independent research cell dedicated to detecting market asymmetries.
              </p>
              <div class="flex flex-col gap-6 text-white/60 text-base leading-relaxed font-light max-w-lg">
                <p>Our approach operates at the intersection of fundamental macroeconomics and quantitative finance.</p>
                <p>We map global liquidity flows and volatility regimes to anticipate structural cycles, designing probabilistic frameworks that stress-test our convictions with total objectivity. Pure signal, not noise.</p>
              </div>
            </div>

            <!-- Right Column: Logo -->
            <div class="reveal reveal-delay-1 flex justify-center lg:justify-end">
              <div class="relative w-full max-w-[500px] aspect-square flex items-center justify-center p-8">
                <!-- Decorative pulse/glow behind logo -->
                <div class="absolute inset-0 bg-blue-3/5 rounded-full blur-[100px] animate-pulse"></div>
                <div class="absolute inset-4 border border-white/5 rounded-full"></div>
                <div class="absolute inset-12 border border-white/5 rounded-full border-dashed animate-[spin_60s_linear_infinite]"></div>
                
                <img src="/assets/img/biglogo.png" alt="Horacle Capital Logo" class="relative z-10 w-48 md:w-72 lg:w-80 opacity-90 drop-shadow-2xl rounded-full" />
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- ACADEMY & PORTFOLIO : DUAL PILLARS -->
      <section class="py-32 border-t border-border bg-white relative">
        <div class="container relative z-10">
          <div class="text-center max-w-3xl mx-auto mb-20 reveal">
            <h2 class="font-head text-4xl md:text-5xl text-text mb-6 tracking-tight">From theory to application</h2>
            <div class="w-16 h-px bg-blue-3 mx-auto mb-6"></div>
            <p class="text-off text-lg leading-relaxed font-sans">
              The Horacle Capital ecosystem rests on two major pillars: transmitting our methodology through an exclusive mentorship program, and transparently putting our macroeconomic research into practice through our market convictions.
            </p>
          </div>

          <div class="grid lg:grid-cols-2 border border-border shadow-xl reveal reveal-delay-1">

            <!-- Academy Side -->
            <article class="p-12 md:p-16 border-b lg:border-b-0 lg:border-r border-border bg-white relative overflow-hidden group">
              <div class="absolute top-0 right-0 w-64 h-64 bg-blue-50 blur-[100px] rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>
              <div class="relative z-10 h-full flex flex-col">
                <span class="text-xs uppercase tracking-widest text-blue-3 font-bold mb-8 block font-sans">Macroeconomic Education</span>
                <h3 class="font-head text-3xl md:text-4xl text-text mb-6 leading-[1.1] group-hover:text-blue-3 transition-colors">Horacle Academy</h3>
                <p class="text-off text-base leading-relaxed mb-10 flex-1 font-sans">
                  Stop enduring the markets. Learn to anticipate them through <strong class="font-bold text-text">private 1-on-1 mentorship</strong> designed for demanding investors. Master liquidity cycles, central bank impact, and our institutional analysis framework.
                </p>
                <div class="pt-8 border-t border-border mt-auto">
                  <a href={l("/academy")} class="inline-flex items-center gap-3 text-sm font-bold text-text group-hover:text-blue-3 transition-colors font-sans">
                    Explore the program <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </a>
                </div>
              </div>
            </article>

            <!-- Portfolio Side -->
            <article class="p-12 md:p-16 bg-bg-2 relative overflow-hidden group">
              <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none" style="background-image: radial-gradient(var(--blue-3) 1px, transparent 1px); background-size: 20px 20px;"></div>
              <div class="relative z-10 h-full flex flex-col">
                <span class="text-xs uppercase tracking-widest text-blue-3 font-bold mb-8 block font-sans">Strategic Execution</span>
                <h3 class="font-head text-3xl md:text-4xl text-text mb-6 leading-[1.1] group-hover:text-blue-3 transition-colors">Model Portfolio</h3>
                <p class="text-off text-base leading-relaxed mb-10 flex-1 font-sans">
                  The direct application of our macroeconomic research. Discover our <strong class="font-bold text-text">asymmetric investment theses</strong> on equities, commodities, and currencies — argued, followed over time, with strict risk management.
                </p>
                <div class="pt-8 border-t border-border/50 mt-auto">
                  <a href={l("/portfolio")} class="inline-flex items-center gap-3 text-sm font-bold text-text group-hover:text-blue-3 transition-colors font-sans">
                    View our convictions <span class="group-hover:translate-x-1 transition-transform">→</span>
                  </a>
                </div>
              </div>
            </article>

          </div>
        </div>
      </section>

      <!-- CTA SECTION -->
      <section class="py-12">
        <div class="container">
          <SubscribeCTA 
            title={t('home.cta.title')}
            description={t('home.cta.description')}
            buttonText={t('home.cta.button')}
            secondaryButtonText={t('home.cta.secondary')}
          />
        </div>
      </section>

      <!-- FAQ SECTION -->
      <MacroFAQ lang="en" />

    </main>
</BaseLayout>
---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import TagList from '../../components/TagList.astro';

export async function getStaticPaths() {
  const rapports = await getCollection('rapports');
  const recherches = await getCollection('recherches');
  
  const allContent = [...rapports, ...recherches];
  const tags = [...new Set(allContent.flatMap(post => post.data.tags || []))];

  return tags.map(tag => {
    const slug = tag.toLowerCase().replace(/\s+/g, '-');
    return {
      params: { tag: slug },
      props: { tag, posts: allContent.filter(post => post.data.tags?.includes(tag)) }
    };
  });
}

const { tag, posts } = Astro.props;
const title = `Contenu tagué "${tag}" | Horacle Capital`;
const description = `Retrouvez toutes nos analyses et recherches liées à : ${tag}.`;

// Sort posts by date
posts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout {title} {description}>
    <header class="py-16 bg-dark text-white border-b border-border-dk">
        <div class="container">
            <span class="font-sans text-[0.6rem] uppercase tracking-[0.3em] text-blue-3 font-bold mb-4 block">Archives par Tag</span>
            <h1 class="font-head text-5xl md:text-6xl mb-6">#{tag}</h1>
            <p class="text-off text-lg max-w-2xl">{posts.length} publication{posts.length > 1 ? 's' : ''} associée{posts.length > 1 ? 's' : ''}.</p>
        </div>
    </header>

    <main class="py-12 bg-bg">
        <div class="container">
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {posts.map(post => (
                    <article class="bg-white border border-border flex flex-col group hover:border-blue-3 transition-colors">
                        <div class="p-8 flex-1 flex flex-col">
                            <div class="flex items-center justify-between mb-4">
                                <span class="font-sans text-[0.6rem] text-dim uppercase tracking-widest">{post.data.date}</span>
                                <span class="bg-bg-2 text-text border border-border font-sans text-[0.5rem] uppercase tracking-wider px-2 py-0.5 font-bold">
                                    {post.collection}
                                </span>
                            </div>
                            <h2 class="font-head text-2xl text-text mb-4 group-hover:text-blue-3 transition-colors">
                                <a href={`/${post.collection}/${post.slug}`}>{post.data.title}</a>
                            </h2>
                            <p class="text-off text-sm leading-relaxed line-clamp-3 mb-6 flex-1">{post.data.description}</p>
                            
                            <TagList tags={post.data.tags || []} class="mt-auto pt-4 border-t border-border" />
                        </div>
                    </article>
                ))}
            </div>
        </div>
    </main>
</BaseLayout>

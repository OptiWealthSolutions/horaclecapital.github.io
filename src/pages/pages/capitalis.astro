---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Capitalis | Infrastructure de Recherche Quantitative";
const description = "L'Alpha est dans la donnée. Capitalis centralise screening, scoring et allocation dynamique dans un workflow de grade institutionnel.";
---

<BaseLayout {title} {description} activeNav="capitalis">
    <style>
      /* ─── CUSTOM HEADER OVERRIDE ─── */
      :global(nav) {
        background: rgba(15, 23, 42, 0.8) !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
      }

      .funnel-hero {
        background: var(--dark);
        padding: clamp(120px, 15vh, 180px) 0 100px;
        position: relative;
        overflow: hidden;
        text-align: center;
      }
      
      .funnel-hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 50% 50%, rgba(37, 99, 235, 0.15) 0%, transparent 70%);
        z-index: 0;
      }

      .hero-tag {
        display: inline-block;
        font-family: var(--ff-body);
        font-size: 0.65rem;
        font-weight: 700;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--blue-3);
        margin-bottom: 2rem;
        padding: 6px 16px;
        border: 1px solid rgba(96, 165, 250, 0.3);
        border-radius: 100px;
      }

      .hero-title {
        font-family: var(--ff-head);
        font-size: clamp(3rem, 7vw, 5.5rem);
        line-height: 0.95;
        letter-spacing: -0.03em;
        color: #fff;
        margin-bottom: 2rem;
        max-width: 1200px;
        margin-left: auto;
        margin-right: auto;
      }

      .hero-sub {
        font-family: var(--ff-body);
        font-size: 1.1rem;
        color: rgba(255, 255, 255, 0.6);
        max-width: 600px;
        margin: 0 auto 3.5rem;
        line-height: 1.6;
      }

      .brand-accent {
        font-family: 'DM Sans', sans-serif !important;
        font-weight: 700;
        letter-spacing: 0.05em;
      }

      .problem-section {
        padding: 80px 0;
        background: #0a0f1e;
        border-top: 1px solid var(--border-dk);
      }

      .problem-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 60px;
        align-items: center;
      }

      .problem-box {
        padding: 40px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border-dk);
      }

      .problem-box h3 {
        font-family: var(--ff-head);
        font-size: 1.8rem;
        color: #fff;
        margin-bottom: 1.2rem;
      }

      .video-section {
        padding: 80px 0;
        background: var(--dark);
        border-top: 1px solid var(--border-dk);
      }

      .video-frame {
        position: relative;
        width: 100%;
        max-width: 1000px;
        margin: 0 auto;
        background: #000;
        border: 1px solid var(--border-dk);
        box-shadow: 0 40px 100px rgba(0,0,0,0.5);
        aspect-ratio: 16/9;
        overflow: hidden;
      }

      .modules-section {
        padding: 100px 0;
        background: var(--white);
      }

      .module-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 2px;
        background: var(--border);
        border: 1px solid var(--border);
      }

      .module-card {
        background: var(--white);
        padding: 50px 40px;
        transition: background 0.3s;
      }

      .module-card:hover {
        background: var(--bg-2);
      }

      .module-num {
        font-family: var(--ff-body);
        font-size: 0.7rem;
        font-weight: 800;
        color: var(--blue-2);
        margin-bottom: 16px;
        display: block;
      }

      .module-title {
        font-family: var(--ff-head);
        font-size: 1.6rem;
        margin-bottom: 12px;
        color: var(--text);
      }

      .module-desc {
        font-size: 0.9rem;
        color: var(--off);
        line-height: 1.6;
      }

      .final-cta {
        padding: 100px 0;
        background: var(--dark);
        text-align: center;
        border-top: 1px solid var(--border-dk);
      }

      @media (max-width: 1024px) {
        .problem-grid { grid-template-columns: 1fr; }
        .module-grid { grid-template-columns: 1fr 1fr; }
      }
      @media (max-width: 768px) {
        .module-grid { grid-template-columns: 1fr; }
      }
    </style>

    <main>
      <!-- HERO -->
      <section class="funnel-hero">
        <div class="container">
          <span class="hero-tag reveal">Technologie Propriétaire</span>
          <h1 class="hero-title reveal">L'Alpha par la donnée.<br><span class="brand-accent text-blue-3">CAPITALIS.</span></h1>
          <p class="hero-sub reveal reveal-delay-1">Centralisez votre recherche. Filtrez le bruit. Prenez des décisions rationnelles.</p>
          <div class="flex justify-center gap-6 reveal reveal-delay-2">
            <a href="https://capitalisapp.pages.dev/dashboard" target="_blank" class="btn-primary" style="padding: 16px 40px;">
              Dashboard
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-left:12px;"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
            <a href="#demo" class="btn-ghost" style="padding: 16px 40px; color:#fff; border-color:rgba(255,255,255,0.2);">Démo</a>
          </div>
        </div>
      </section>

      <!-- PROBLEM SECTION -->
      <section class="problem-section">
        <div class="container">
          <div class="problem-grid">
            <div class="reveal">
              <h2 class="section-label" style="color:var(--blue-3);">Le Constat</h2>
              <h3 class="font-head text-4xl text-white mt-4 mb-6">L'erreur est humaine.</h3>
              <p class="text-white/50 leading-relaxed mb-8">Les biais cognitifs détruisent la performance. Capitalis élimine l'émotion de votre processus d'investissement.</p>
              <div class="grid gap-3">
                <div class="flex items-center gap-4 text-white/70 font-sans text-xs uppercase tracking-widest">
                  <div class="w-1.5 h-1.5 bg-red-500 rounded-full"></div> Données fragmentées
                </div>
                <div class="flex items-center gap-4 text-white/70 font-sans text-xs uppercase tracking-widest">
                  <div class="w-1.5 h-1.5 bg-red-500 rounded-full"></div> Subjectivité
                </div>
              </div>
            </div>
            <div class="problem-box reveal reveal-delay-1">
              <span class="hero-tag" style="margin-bottom:20px; border-color:var(--blue-2); color:var(--blue-2);">Solution</span>
              <h3>Un Workflow Unifié.</h3>
              <p class="text-white/60 leading-relaxed text-sm">Une infrastructure complète pour piloter vos actifs avec une rigueur institutionnelle.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- VIDEO DEMO -->
      <section id="demo" class="video-section">
        <div class="container text-center">
          <div class="section-rule mb-10" style="--border:rgba(255,255,255,0.1)">
            <span class="section-label" style="color:rgba(255,255,255,0.4);">Capacités v1.0</span>
            <div class="rule-line"></div>
          </div>
          <div class="video-frame reveal">
            <video class="w-full h-full" autoplay loop muted playsinline controls preload="metadata" style="object-fit: cover;">
              <source src="/assets/videos/CapitalisVideo.mp4" type="video/mp4">
            </video>
          </div>
        </div>
      </section>

      <!-- MODULES GRID -->
      <section class="modules-section">
        <div class="container">
          <div class="section-rule mb-16">
            <h2 class="section-label">Modules</h2>
            <div class="rule-line"></div>
          </div>
          
          <div class="module-grid reveal">
            <div class="module-card">
              <span class="module-num">01. SCREENER</span>
              <h3 class="module-title">Filtrage</h3>
              <p class="module-desc">Isolez les meilleures opportunités via des critères macro et fondamentaux.</p>
            </div>
            <div class="module-card">
              <span class="module-num">02. SCORER</span>
              <h3 class="module-title">Notation</h3>
              <p class="module-desc">Classement objectif des actifs par matrice multifactorielle.</p>
            </div>
            <div class="module-card">
              <span class="module-num">03. MARKET MAP</span>
              <h3 class="module-title">Flux</h3>
              <p class="module-desc">Visualisez les rotations sectorielles en temps réel.</p>
            </div>
            <div class="module-card">
              <span class="module-num">04. ALLOCATION</span>
              <h3 class="module-title">Risque</h3>
              <p class="module-desc">Optimisez vos poids selon la volatilité et les corrélations.</p>
            </div>
            <div class="module-card">
              <span class="module-num">05. EQUITY REVIEW</span>
              <h3 class="module-title">Analyse</h3>
              <p class="module-desc">Vue 360° : data financière et technique unifiée.</p>
            </div>
            <div class="module-card">
              <span class="module-num">06. REPORTING</span>
              <h3 class="module-title">Audit</h3>
              <p class="module-desc">Générez vos rapports de performance institutionnels.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- FINAL CTA -->
      <section class="final-cta">
        <div class="container max-w-[700px]">
          <span class="hero-tag mb-8">Accès Bêta</span>
          <h2 class="font-head text-4xl text-white mb-6">Passez à la vitesse supérieure.</h2>
          <p class="text-lg text-white/50 mb-10">Rejoignez l'élite des investisseurs utilisant la donnée.</p>
          <a href="https://capitalisapp.pages.dev/dashboard" target="_blank" class="btn-primary" style="padding: 16px 50px;">
            Lancer <span class="brand-accent">CAPITALIS</span>
          </a>
        </div>
      </section>
    </main>
</BaseLayout>

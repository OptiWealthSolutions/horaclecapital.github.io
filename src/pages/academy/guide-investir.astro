---
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = "Guide : Commencer à Investir en 2026 | Horacle Academy";
const description = "Rejoignez la liste d'attente pour notre guide stratégique. ETF, Stock Picking, DCA et psychologie de l'investisseur.";
---

<style>
    /* 3D Ebook CSS */
    .book-container {
        perspective: 1000px;
    }
    .book {
        width: 320px;
        height: 460px;
        position: relative;
        transform-style: preserve-3d;
        transform: rotateY(-20deg) rotateX(5deg);
        transition: transform 0.5s ease;
    }
    .book:hover {
        transform: rotateY(-10deg) rotateX(0deg);
    }
    .book-front {
        position: absolute;
        width: 320px;
        height: 460px;
        background: #0F172A;
        border: 4px solid rgba(255,255,255,0.15);
        z-index: 2;
        transform: translateZ(15px);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 0;
        box-shadow: 20px 20px 60px rgba(0,0,0,0.6);
    }
    .book-spine {
        position: absolute;
        width: 30px;
        height: 460px;
        background: #1C2236;
        left: -15px;
        transform: rotateY(-90deg);
        border: 1px solid rgba(255,255,255,0.1);
    }
    .book-top {
        position: absolute;
        width: 320px;
        height: 30px;
        background: #e5e7eb;
        top: -15px;
        transform: rotateX(90deg);
    }
    .book-shadow {
        position: absolute;
        width: 320px;
        height: 30px;
        background: rgba(0,0,0,0.3);
        bottom: -50px;
        filter: blur(20px);
        transform: rotateX(90deg);
    }

    /* Fix Button Contrast */
    .btn-primary-fix {
        background-color: #2563EB !important;
        color: white !important;
        border: none !important;
    }
    .btn-primary-fix:hover {
        background-color: #1D4ED8 !important;
        color: white !important;
    }
</style>

<BaseLayout {title} {description} activeNav="academy">
    <main class="bg-white min-h-screen">
        
        <!-- HERO SECTION -->
        <header class="bg-dark text-white pt-48 pb-48 overflow-hidden border-b border-white/5 relative">
            <div class="absolute inset-0 opacity-20 bg-[url('/assets/img/banner.jpg')] bg-cover bg-center"></div>
            <div class="absolute inset-0 bg-dark/80"></div>
            <div class="container flex flex-col lg:flex-row items-center gap-20 relative z-10">
                <div class="flex-1 text-center lg:text-left">
                    <h1 class="font-head text-5xl md:text-7xl mb-8 leading-tight tracking-tight">
                        L'investissement <span class="text-blue-500">honnête.</span>
                        <span class="block text-2xl md:text-3xl mt-4 text-white/40 font-sans font-light italic">Bientôt Disponible</span>
                    </h1>
                    <p class="text-white/60 text-lg md:text-xl mb-12 max-w-2xl font-sans leading-relaxed">
                        Sortez du bruit de marché. Apprenez à investir avec la rigueur d'un institutionnel. Inscrivez-vous pour être prévenu de la sortie.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start items-center">
                        <a href="#download" class="btn-primary-fix px-10 py-4 shadow-2xl shadow-blue-600/30 inline-block font-sans font-bold uppercase tracking-widest text-sm">S'inscrire sur la liste</a>
                        <div class="flex items-center gap-4 text-white/40 font-mono text-[0.6rem] uppercase tracking-widest">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                            <span>1,500+ Investisseurs en attente</span>
                        </div>
                    </div>
                </div>
                <div class="flex-shrink-0 book-container z-10">
                    <div class="book">
                        <div class="book-spine"></div>
                        <div class="book-top"></div>
                        <div class="book-front p-0 overflow-hidden">
                            <img src="/assets/img/cover_guide.png" alt="Couverture du Guide" class="w-full h-full object-cover" />
                        </div>
                        <div class="book-shadow"></div>
                    </div>
                </div>
            </div>
        </header>

        <!-- SECTION BESOIN / POURQUOI -->
        <section class="py-32 bg-white">
            <div class="container max-w-4xl">
                <div class="text-center mb-16">
                    <span class="text-blue-600 font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-4 block">The Problem</span>
                    <h2 class="font-head text-4xl text-dark mb-6">Pourquoi ce guide ?</h2>
                </div>
                <div class="space-y-8 text-slate-600 text-lg font-sans font-light leading-relaxed">
                    <p>Internet est saturé de "conseils" financiers. Entre les vendeurs de rêves qui promettent la fortune en 3 clics et les banquiers qui vous enferment dans des produits aux frais cachés, l'investisseur particulier est souvent la proie du système.</p>
                    <p><strong class="text-dark font-medium">Nous avons créé ce guide pour briser ce cycle.</strong></p>
                    <p>La vérité est simple : investir n'est pas censé être un casino. C'est un processus rigoureux, mathématique et psychologique. Nous voulons transmettre les codes des institutionnels (gestion de risque, allocation dynamique, analyse macro) pour que vous puissiez enfin reprendre le contrôle de votre capital, sans dépendre du bruit ambiant.</p>
                </div>
            </div>
        </section>

        <!-- SECTION EXPERTISE (Léo & Raphaël) -->
        <section class="py-32 bg-slate-50 border-y border-slate-200">
            <div class="container">
                <div class="text-center mb-20">
                    <span class="text-blue-600 font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-4 block">Our Expertise</span>
                    <h2 class="font-head text-4xl text-dark">Qui sommes-nous ?</h2>
                </div>
                <div class="grid md:grid-cols-2 gap-16 max-w-5xl mx-auto">
                    <!-- Léo -->
                    <div class="flex flex-col items-center text-center lg:flex-row lg:text-left gap-8">
                        <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-xl flex-shrink-0 grayscale">
                            <img src="/assets/img/profil_leo_HD.jpeg" alt="Léo Lombardini" class="w-full h-full object-cover" />
                        </div>
                        <div>
                            <h3 class="font-head text-2xl text-dark mb-2">Léo Lombardini</h3>
                            <p class="text-blue-600 font-mono text-[0.6rem] uppercase tracking-widest mb-4">Fondateur & Stratégiste Quant</p>
                            <p class="text-slate-600 text-sm leading-relaxed font-light font-sans">Spécialisé en modélisation quantitative et macro-économie, Léo a conçu les frameworks d'analyse qu'Horacle Capital utilise aujourd'hui pour son propre portefeuille.</p>
                        </div>
                    </div>
                    <!-- Raphaël -->
                    <div class="flex flex-col items-center text-center lg:flex-row lg:text-left gap-8">
                        <div class="w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-xl flex-shrink-0 grayscale">
                             <img src="/assets/img/photo_profil_raphael.jpg" alt="Raphaël Chouraqui" class="w-full h-full object-cover" />
                        </div>
                        <div>
                            <h3 class="font-head text-2xl text-dark mb-2">Raphaël Chouraqui</h3>
                            <p class="text-blue-600 font-mono text-[0.6rem] uppercase tracking-widest mb-4">Analyste Recherche & Macro</p>
                            <p class="text-slate-600 text-sm leading-relaxed font-light font-sans">Diplômé de l'ESCP, Raphaël décrypte les tendances structurelles pour transformer les données économiques complexes en thèses d'investissement cohérentes.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- SECTION TEMOIGNAGES -->
        <section class="py-32 bg-white overflow-hidden">
            <div class="container">
                <div class="text-center mb-20">
                    <span class="text-blue-600 font-mono text-[0.65rem] uppercase tracking-[0.3em] font-bold mb-4 block">Feedback</span>
                    <h2 class="font-head text-4xl text-dark">Ils nous font confiance</h2>
                </div>
                <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
                    <!-- Témoignage 1 -->
                    <div class="p-8 border border-slate-100 bg-slate-50/30">
                        <div class="flex gap-1 text-blue-500 mb-6">
                            {[1, 2, 3, 4, 5].map(() => (
                                <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            ))}
                        </div>
                        <p class="text-slate-600 italic mb-8 font-sans font-light">"Enfin une approche qui ne repose pas sur de l'espoir mais sur des données concrètes. Léo et son équipe m'ont aidé à restructurer mon PEA avec une vision long terme claire."</p>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-slate-200"></div>
                            <div>
                                <p class="text-dark font-bold text-xs uppercase tracking-widest">Thomas R.</p>
                                <p class="text-slate-400 text-[0.6rem] uppercase tracking-widest">Entrepreneur</p>
                            </div>
                        </div>
                    </div>
                    <!-- Témoignage 2 -->
                    <div class="p-8 border border-slate-100 bg-slate-50/30">
                        <div class="flex gap-1 text-blue-500 mb-6">
                            {[1, 2, 3, 4, 5].map(() => (
                                <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            ))}
                        </div>
                        <p class="text-slate-600 italic mb-8 font-sans font-light">"Leur capacité à vulgariser des concepts macro complexes est impressionnante. Ce guide va devenir la bible de tout investisseur sérieux."</p>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-slate-200"></div>
                            <div>
                                <p class="text-dark font-bold text-xs uppercase tracking-widest">Marc A.</p>
                                <p class="text-slate-400 text-[0.6rem] uppercase tracking-widest">Cadre Supérieur</p>
                            </div>
                        </div>
                    </div>
                    <!-- Témoignage 3 -->
                    <div class="p-8 border border-slate-100 bg-slate-50/30">
                        <div class="flex gap-1 text-blue-500 mb-6">
                            {[1, 2, 3, 4, 5].map(() => (
                                <svg width="16" height="16" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
                            ))}
                        </div>
                        <p class="text-slate-600 italic mb-8 font-sans font-light">"Grâce à leurs conseils, j'ai enfin compris comment utiliser les ETF pour battre l'inflation sans prendre des risques inconsidérés."</p>
                        <div class="flex items-center gap-4">
                            <div class="w-10 h-10 rounded-full bg-slate-200"></div>
                            <div>
                                <p class="text-dark font-bold text-xs uppercase tracking-widest">Sarah L.</p>
                                <p class="text-slate-400 text-[0.6rem] uppercase tracking-widest">Investisseuse Particulière</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FORMULAIRE (WAITLIST) -->
        <section id="download" class="py-32 bg-dark text-white relative overflow-hidden">
            <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/carbon-fibre.png')]"></div>
            <div class="container max-w-3xl relative z-10">
                <div class="bg-white text-dark p-12 md:p-20 shadow-2xl relative">
                    <div class="absolute top-0 left-0 w-full h-2 bg-blue-600"></div>
                    <div class="text-center mb-12">
                        <h2 class="font-head text-4xl mb-4">Rejoindre la liste d'attente</h2>
                        <p class="text-slate-500 font-sans text-sm">Soyez informé en priorité dès que le guide est disponible.</p>
                    </div>

                    <form id="guide-form-final" class="space-y-6">
                        <div>
                            <label for="email-final" class="sr-only">Email</label>
                            <input 
                                type="email" 
                                id="email-final" 
                                name="email" 
                                placeholder="votre@email.com" 
                                required
                                class="w-full px-8 py-5 bg-slate-50 border border-slate-200 focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none transition-all font-sans text-lg text-center text-dark placeholder:text-slate-400"
                            />
                        </div>
                        <button 
                            type="submit" 
                            id="submit-btn-final"
                            class="w-full bg-blue-600 hover:bg-blue-700 text-white font-sans font-bold py-5 uppercase tracking-[0.2em] text-sm shadow-xl transition-all btn-primary-fix"
                        >
                            S'inscrire sur la liste
                        </button>
                    </form>

                    <div id="success-msg-final" class="hidden text-center py-10">
                        <div class="w-16 h-16 bg-green-50 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6 shadow-inner">
                            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <h4 class="font-head text-3xl mb-2 text-dark">Inscription confirmée</h4>
                        <p class="text-slate-700">Vous recevrez un email de confirmation d'ici quelques secondes.</p>
                    </div>
                </div>
            </div>
        </section>

    </main>
</BaseLayout>

<script>
    import { supabase } from '../../lib/supabase';

    const setupForm = (formId, btnId, successId) => {
        const form = document.getElementById(formId) as HTMLFormElement;
        const submitBtn = document.getElementById(btnId) as HTMLButtonElement;
        const successMsg = document.getElementById(successId);

        if (form) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;
                const email = emailInput?.value;

                submitBtn.disabled = true;
                const originalText = submitBtn.textContent;
                submitBtn.textContent = "Chargement...";

                try {
                    const { data, error } = await supabase.functions.invoke('send-investor-guide', {
                        body: { email }
                    });

                    if (error) throw error;

                    form.classList.add('hidden');
                    successMsg?.classList.remove('hidden');
                    successMsg?.scrollIntoView({ behavior: 'smooth', block: 'center' });
                } catch (err) {
                    console.error("Erreur:", err);
                    alert("Une erreur est survenue. Veuillez réessayer.");
                    submitBtn.disabled = false;
                    submitBtn.textContent = originalText;
                }
            });
        }
    };

    setupForm('guide-form-final', 'submit-btn-final', 'success-msg-final');
</script>

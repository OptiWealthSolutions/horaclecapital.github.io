---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = 'Portfolio & Convictions | Horacle Capital';
const description = "Suivez nos portefeuilles modèles et nos convictions de marché basées sur nos analyses macroéconomiques et quantitatives.";

const portfolios = await getCollection('portfolios', ({ data }) => {
  return data.draft !== true;
});

// Sort by date or title
portfolios.sort((a, b) => b.data.lastUpdated.localeCompare(a.data.lastUpdated));
---

<BaseLayout {title} {description} activeNav="portfolio">
    <header class="portfolio-hero relative py-24 md:py-32 overflow-hidden bg-dark">
        <!-- Background Image with Overlay -->
        <div class="absolute inset-0 z-0">
            <img 
                src="/assets/img/report_banner.jpg" 
                alt="" 
                class="w-full h-full object-cover opacity-10 grayscale"
                aria-hidden="true"
            />
        </div>

        <div class="container relative z-10 text-center">
            <div class="max-w-4xl mx-auto">
                <span class="font-sans text-[0.65rem] uppercase tracking-[0.4em] text-blue-3 font-bold mb-6 block reveal">Stratégie & Convictions</span>
                <h1 class="font-head text-5xl md:text-8xl mb-8 text-white leading-[1.1] reveal">Nos Portefeuilles</h1>
                <p class="text-off text-lg md:text-xl leading-relaxed font-light reveal reveal-delay-1 max-w-2xl mx-auto">
                    Transparence totale et rigueur analytique. Nos allocations reflètent nos moteurs de scoring et notre lecture des cycles macroéconomiques.
                </p>
                <div class="mt-12 flex justify-center gap-8 reveal reveal-delay-2">
                    <div class="flex flex-col items-center">
                        <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Mise à jour</span>
                        <span class="text-white font-mono text-xs">Hebdomadaire</span>
                    </div>
                    <div class="w-px h-10 bg-white/10"></div>
                    <div class="flex flex-col items-center">
                        <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Univers</span>
                        <span class="text-white font-mono text-xs">Multi-Assets</span>
                    </div>
                    <div class="w-px h-10 bg-white/10"></div>
                    <div class="flex flex-col items-center">
                        <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Source</span>
                        <span class="text-white font-mono text-xs">yFinance Live</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="py-12 bg-bg">
        <div class="container mb-24">
            <div class="section-rule mb-12">
                <h2 class="section-label">Thèses de Haute Conviction</h2>
                <div class="rule-line"></div>
            </div>
            
            <div class="grid md:grid-cols-3 gap-8">
                <!-- Thesis Card 1: MSFT -->
                <article class="bg-white border border-border group hover:border-blue-3 transition-all duration-500 flex flex-col shadow-sm hover:shadow-xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-blue-3 transform -translate-x-full group-hover:translate-x-0 transition-transform duration-300"></div>
                    <div class="h-48 overflow-hidden border-b border-border relative">
                        <img src="/assets/img/screen_1_terminal.jpeg" alt="Microsoft Analysis" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-1000" />
                        <div class="absolute inset-0 bg-blue-900/10 group-hover:bg-transparent transition-colors duration-500"></div>
                    </div>
                    <div class="p-8 flex-1 flex flex-col">
                        <div class="flex items-center justify-between mb-5">
                            <span class="text-blue-3 text-[0.6rem] font-bold uppercase tracking-[0.2em] px-2 py-1 border border-blue-3/20 bg-blue-50/50">Equities / AI</span>
                            <span class="text-dim text-[0.55rem] font-mono uppercase tracking-widest">Mai 2026</span>
                        </div>
                        <h3 class="font-head text-2xl text-text mb-4 group-hover:text-blue-3 transition-colors leading-tight">Microsoft : La Verticale Infrastructurelle</h3>
                        <p class="text-off text-sm leading-relaxed mb-8 line-clamp-3 font-light italic">Dominance sur le cycle de l'IA via Azure et l'intégration Copilot. Une génération de cash flow inégalée.</p>
                        <div class="mt-auto pt-6 border-t border-border/50 flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[0.55rem] text-dim uppercase tracking-widest mb-1">Conviction</span>
                                <span class="text-[0.7rem] font-bold text-blue-600 uppercase tracking-tighter">Haute</span>
                            </div>
                            <a href="/recherches/microsoft-ai-infra" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-blue-3 group-hover:bg-blue-3 group-hover:text-white group-hover:border-blue-3 transition-all duration-300">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </a>
                        </div>
                    </div>
                </article>

                <!-- Thesis Card 2: Copper -->
                <article class="bg-white border border-border group hover:border-blue-3 transition-all duration-500 flex flex-col shadow-sm hover:shadow-xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-blue-3 transform -translate-x-full group-hover:translate-x-0 transition-transform duration-300"></div>
                    <div class="h-48 overflow-hidden border-b border-border relative">
                        <img src="/assets/img/gold_oil_price.png" alt="Copper Analysis" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-1000" />
                        <div class="absolute inset-0 bg-blue-900/10 group-hover:bg-transparent transition-colors duration-500"></div>
                    </div>
                    <div class="p-8 flex-1 flex flex-col">
                        <div class="flex items-center justify-between mb-5">
                            <span class="text-blue-3 text-[0.6rem] font-bold uppercase tracking-[0.2em] px-2 py-1 border border-blue-3/20 bg-blue-50/50">Commodities</span>
                            <span class="text-dim text-[0.55rem] font-mono uppercase tracking-widest">Avril 2026</span>
                        </div>
                        <h3 class="font-head text-2xl text-text mb-4 group-hover:text-blue-3 transition-colors leading-tight">Cuivre : Le Signal de l'Électrification</h3>
                        <p class="text-off text-sm leading-relaxed mb-8 line-clamp-3 font-light italic">Déficit structurel de l'offre vs demande exponentielle des data centers et de la transition énergétique.</p>
                        <div class="mt-auto pt-6 border-t border-border/50 flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[0.55rem] text-dim uppercase tracking-widest mb-1">Conviction</span>
                                <span class="text-[0.7rem] font-bold text-orange-600 uppercase tracking-tighter">Moyenne</span>
                            </div>
                            <a href="/recherches/copper-electrification" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-blue-3 group-hover:bg-blue-3 group-hover:text-white group-hover:border-blue-3 transition-all duration-300">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </a>
                        </div>
                    </div>
                </article>

                <!-- Thesis Card 3: USD -->
                <article class="bg-white border border-border group hover:border-blue-3 transition-all duration-500 flex flex-col shadow-sm hover:shadow-xl relative overflow-hidden">
                    <div class="absolute top-0 left-0 w-1 h-full bg-blue-3 transform -translate-x-full group-hover:translate-x-0 transition-transform duration-300"></div>
                    <div class="h-48 overflow-hidden border-b border-border relative">
                        <img src="/assets/img/us_CPI_APRIL.png" alt="USD Analysis" class="w-full h-full object-cover grayscale group-hover:grayscale-0 group-hover:scale-110 transition-all duration-1000" />
                        <div class="absolute inset-0 bg-blue-900/10 group-hover:bg-transparent transition-colors duration-500"></div>
                    </div>
                    <div class="p-8 flex-1 flex flex-col">
                        <div class="flex items-center justify-between mb-5">
                            <span class="text-blue-3 text-[0.6rem] font-bold uppercase tracking-[0.2em] px-2 py-1 border border-blue-3/20 bg-blue-50/50">FX / Macro</span>
                            <span class="text-dim text-[0.55rem] font-mono uppercase tracking-widest">Mars 2026</span>
                        </div>
                        <h3 class="font-head text-2xl text-text mb-4 group-hover:text-blue-3 transition-colors leading-tight">USD : Taux Réels & Exceptionnalisme</h3>
                        <p class="text-off text-sm leading-relaxed mb-8 line-clamp-3 font-light italic">Analyse de la persistance de la force du Dollar face aux flux de capitaux cherchant le rendement réel.</p>
                        <div class="mt-auto pt-6 border-t border-border/50 flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[0.55rem] text-dim uppercase tracking-widest mb-1">Conviction</span>
                                <span class="text-[0.7rem] font-bold text-green-600 uppercase tracking-tighter">Haute</span>
                            </div>
                            <a href="/recherches/usd-macro-dominance" class="w-10 h-10 rounded-full border border-border flex items-center justify-center text-blue-3 group-hover:bg-blue-3 group-hover:text-white group-hover:border-blue-3 transition-all duration-300">
                                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                            </a>
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <div class="container">
            <div class="section-rule mb-12">
                <h2 class="section-label">Nos Portefeuilles Modèles</h2>
                <div class="rule-line"></div>
            </div>

            {portfolios.length === 0 ? (
                <div class="py-20 text-center border border-dashed border-border">
                    <p class="text-dim">Aucun portfolio disponible pour le moment.</p>
                </div>
            ) : (
                <div class="grid gap-20">
                    {portfolios.map(async (portfolio) => {
                        const { Content } = await portfolio.render();
                        const isNegativeYtd = portfolio.data.stats.ytd.startsWith('-');
                        const isNegativeSharpe = portfolio.data.stats.sharpe.startsWith('-');
                        
                        return (
                            <section class="portfolio-card bg-white border border-border shadow-sm overflow-hidden mb-16">
                                <!-- Institutional Header Bar -->
                                <div class="bg-dark text-white p-4 px-8 flex justify-between items-center border-b border-blue-3">
                                    <div class="flex items-center gap-4">
                                        <span class="font-mono text-[0.6rem] uppercase tracking-[0.3em] text-blue-3 font-bold">Modèle d'Allocation</span>
                                        <span class="w-1.5 h-1.5 bg-blue-3 rounded-full animate-pulse"></span>
                                        <span class="text-[0.65rem] font-mono text-dim uppercase hidden sm:inline">Strategy ID: {portfolio.id.toUpperCase()}</span>
                                    </div>
                                    <span class="text-[0.6rem] font-mono text-dim uppercase tracking-widest italic">Actualisé : {portfolio.data.lastUpdated}</span>
                                </div>
                                
                                <div class="p-8 md:p-12">
                                    <div class="grid lg:grid-cols-[1fr_auto] gap-12 items-start mb-16">
                                        <div>
                                            <div class="flex items-center gap-3 mb-6">
                                                <span class={`px-3 py-1 text-[0.6rem] font-bold uppercase tracking-widest ${
                                                    portfolio.data.riskLevel === 'High' ? 'bg-red-600 text-white' : 
                                                    portfolio.data.riskLevel === 'Medium' ? 'bg-orange-500 text-white' : 
                                                    'bg-blue-600 text-white'
                                                }`}>
                                                    Profil {portfolio.data.riskLevel}
                                                </span>
                                                <span class="w-px h-4 bg-border"></span>
                                                <span class="text-[0.6rem] text-dim uppercase tracking-widest font-mono">Multi-Asset Class</span>
                                            </div>
                                            <h2 class="font-head text-5xl md:text-6xl text-text mb-8 leading-tight italic">{portfolio.data.title}</h2>
                                            <p class="text-off text-lg leading-relaxed max-w-3xl font-light italic">{portfolio.data.description}</p>
                                        </div>
                                        
                                        <!-- Key Metrics Dashboard -->
                                        <div class="grid grid-cols-3 gap-0 border border-border bg-bg-2 divide-x divide-border shadow-inner">
                                            <div class="text-center p-8 min-w-[140px]">
                                                <span class="block text-[0.55rem] text-dim uppercase tracking-widest mb-4">Perf. YTD</span>
                                                <span class={`block text-4xl font-head font-bold ${isNegativeYtd ? 'text-red-600' : 'text-green-600'}`}>
                                                    {portfolio.data.stats.ytd}
                                                </span>
                                            </div>
                                            <div class="text-center p-8 min-w-[140px]">
                                                <span class="block text-[0.55rem] text-dim uppercase tracking-widest mb-4">Sharpe</span>
                                                <span class={`block text-4xl font-head font-bold ${isNegativeSharpe ? 'text-red-600' : 'text-text'}`}>
                                                    {portfolio.data.stats.sharpe}
                                                </span>
                                            </div>
                                            <div class="text-center p-8 min-w-[140px]">
                                                <span class="block text-[0.55rem] text-dim uppercase tracking-widest mb-4">Volatilité</span>
                                                <span class="block text-4xl font-head text-text font-bold">{portfolio.data.stats.volatility}</span>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Table Container -->
                                    <div class="mb-16 overflow-hidden border border-border bg-white shadow-sm">
                                        <div class="bg-dark text-white px-8 py-4 flex justify-between items-center border-b border-blue-3">
                                            <h3 class="font-mono text-[0.65rem] uppercase tracking-[0.2em] font-bold">Composition du Portefeuille</h3>
                                            <span class="text-[0.6rem] text-dim uppercase font-mono">{portfolio.data.positions.length} Positions Ouvertes</span>
                                        </div>
                                        <div class="overflow-x-auto">
                                            <table class="w-full text-left border-collapse">
                                                <thead>
                                                    <tr class="bg-bg-2 text-text text-[0.65rem] uppercase tracking-[0.1em] font-bold border-b border-border">
                                                        <th class="px-8 py-5">Classe d'Actif</th>
                                                        <th class="px-8 py-5">Instrument</th>
                                                        <th class="px-8 py-5">Allocation</th>
                                                        <th class="px-8 py-5">Conviction</th>
                                                        <th class="px-8 py-5">Rationale Stratégique</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="divide-y divide-border/30">
                                                    {portfolio.data.positions.map((pos) => (
                                                        <tr class="hover:bg-blue-50/40 transition-colors group/row">
                                                            <td class="px-8 py-6">
                                                                <span class="text-[0.65rem] text-blue-3 font-mono font-bold uppercase border border-blue-3/10 px-2 py-0.5 bg-blue-50/30">{pos.type}</span>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <div class="flex flex-col">
                                                                    <span class="font-head text-xl text-text font-bold group-hover/row:text-blue-3 transition-colors">{pos.asset}</span>
                                                                </div>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <div class="flex items-center gap-4">
                                                                    <span class="font-mono text-base font-bold text-text">{pos.weight}</span>
                                                                    <div class="hidden xl:block w-24 h-1.5 bg-border rounded-none overflow-hidden">
                                                                        <div class="h-full bg-blue-3 shadow-[0_0_8px_rgba(37,99,235,0.4)]" style={`width: ${pos.weight}`}></div>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                            <td class="px-8 py-6">
                                                                <span class={`px-2 py-1 text-[0.6rem] font-bold uppercase border ${
                                                                    pos.conviction === 'High' ? 'border-blue-300 text-blue-700 bg-blue-50' : 
                                                                    pos.conviction === 'Medium' ? 'border-orange-300 text-orange-700 bg-orange-50' : 
                                                                    'border-gray-200 text-dim bg-bg-2'
                                                                }`}>
                                                                    {pos.conviction}
                                                                </span>
                                                            </td>
                                                            <td class="px-8 py-6 text-off text-sm italic font-light leading-relaxed max-w-sm">{pos.thesis}</td>
                                                        </tr>
                                                    ))}
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    
                                    <!-- Analysis Content -->
                                    <div class="prose prose-lg max-w-none pt-12 border-t border-border prose-headings:font-head prose-headings:italic prose-headings:text-text prose-p:text-off prose-p:leading-relaxed prose-strong:text-text prose-strong:font-bold">
                                        <Content />
                                    </div>
                                </div>
                            </section>
                        );
                    })}
                </div>
            )}
        </div>
    </main>
</BaseLayout>

<style>
    .portfolio-card {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    
    table th {
        border-bottom: 2px solid var(--blue-3);
    }
    
    tr:last-child td {
        border-bottom: none;
    }
</style>

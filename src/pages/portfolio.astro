---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const title = 'Portfolio & Convictions | Horacle Capital';
const description = "Suivez nos portefeuilles modèles et nos convictions de marché basées sur nos analyses macroéconomiques et quantitatives.";

const portfolios = await getCollection('portfolios', ({ data }) => {
  return data.draft !== true;
});

// Sort by date or title
portfolios.sort((a, b) => b.data.lastUpdated.localeCompare(a.data.lastUpdated));
---

<BaseLayout {title} {description} activeNav="portfolio">
    <header class="portfolio-hero relative py-24 md:py-32 overflow-hidden bg-dark">
        <!-- Background Image with Overlay -->
        <div class="absolute inset-0 z-0">
            <img 
                src="/assets/img/report_banner.jpg" 
                alt="" 
                class="w-full h-full object-cover opacity-10 grayscale"
                aria-hidden="true"
            />
        </div>

        <div class="container relative z-10 text-center">
            <div class="max-w-4xl mx-auto">
                <span class="font-sans text-[0.65rem] uppercase tracking-[0.4em] text-blue-3 font-bold mb-6 block reveal">Stratégie & Convictions</span>
                <h1 class="font-head text-5xl md:text-8xl mb-8 text-white leading-[1.1] reveal">Nos Portefeuilles</h1>
                <p class="text-off text-lg md:text-xl leading-relaxed font-light reveal reveal-delay-1 max-w-2xl mx-auto">
                    Transparence totale et rigueur analytique. Nos allocations reflètent nos moteurs de scoring et notre lecture des cycles macroéconomiques.
                </p>
                <div class="mt-12 flex justify-center gap-8 reveal reveal-delay-2">
                    <div class="flex flex-col items-center">
                        <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Mise à jour</span>
                        <span class="text-white font-mono text-xs">Hebdomadaire</span>
                    </div>
                    <div class="w-px h-10 bg-white/10"></div>
                    <div class="flex flex-col items-center">
                        <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Univers</span>
                        <span class="text-white font-mono text-xs">Multi-Assets</span>
                    </div>
                    <div class="w-px h-10 bg-white/10"></div>
                    <div class="flex flex-col items-center">
                        <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Source</span>
                        <span class="text-white font-mono text-xs">yFinance Live</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="py-12 bg-bg">
        <div class="container mb-24">
            <div class="section-rule mb-12">
                <h2 class="section-label">Thèses de Haute Conviction</h2>
                <div class="rule-line"></div>
            </div>
            
            <div class="grid lg:grid-cols-3 gap-6 lg:gap-8">
                <!-- Thesis Card 1: MSFT -->
                <article class="group relative flex flex-col bg-white border border-border hover:border-blue-3 transition-colors shadow-sm hover:shadow-md overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-blue-3 scale-x-0 group-hover:scale-x-100 transition-transform origin-left z-10"></div>
                    
                    <div class="h-48 overflow-hidden border-b border-border relative">
                        <img src="https://images.unsplash.com/photo-1620714223084-8fcacc6dfd8d?auto=format&fit=crop&w=800&q=80" alt="Microsoft AI" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" />
                        <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
                    </div>
                    
                    <div class="p-8 flex flex-col flex-1">
                        <div class="flex items-center justify-between mb-6 pb-6 border-b border-border/50">
                            <span class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-3">Equities / AI</span>
                            <span class="text-[0.65rem] text-dim uppercase tracking-widest">Mai 2026</span>
                        </div>
                        
                        <h3 class="font-head text-3xl text-text mb-6 leading-tight group-hover:text-blue-3 transition-colors">Microsoft : La Verticale Infrastructurelle</h3>
                        
                        <p class="text-off text-base leading-relaxed mb-8 flex-1">Dominance sur le cycle de l'IA via Azure et l'intégration Copilot. Une génération de cash flow inégalée.</p>
                        
                        <div class="mt-auto pt-6 flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Conviction</span>
                                <span class="text-[0.75rem] font-bold text-blue-600 uppercase tracking-wide">Haute</span>
                            </div>
                            <a href="/recherches/microsoft-ai-infra" class="inline-flex items-center gap-2 text-[0.7rem] uppercase tracking-widest font-bold text-text group-hover:text-blue-3 transition-colors">
                                Lire <span class="group-hover:translate-x-1 transition-transform">→</span>
                            </a>
                        </div>
                    </div>
                </article>

                <!-- Thesis Card 2: Copper -->
                <article class="group relative flex flex-col bg-white border border-border hover:border-blue-3 transition-colors shadow-sm hover:shadow-md overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-blue-3 scale-x-0 group-hover:scale-x-100 transition-transform origin-left z-10"></div>
                    
                    <div class="h-48 overflow-hidden border-b border-border relative">
                        <img src="https://images.unsplash.com/photo-1509391366360-2e959784a276?auto=format&fit=crop&w=800&q=80" alt="Solar Energy & Copper" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" />
                        <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
                    </div>
                    
                    <div class="p-8 flex flex-col flex-1">
                        <div class="flex items-center justify-between mb-6 pb-6 border-b border-border/50">
                            <span class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-3">Commodities</span>
                            <span class="text-[0.65rem] text-dim uppercase tracking-widest">Avril 2026</span>
                        </div>
                        
                        <h3 class="font-head text-3xl text-text mb-6 leading-tight group-hover:text-blue-3 transition-colors">Cuivre : Le Signal de l'Électrification</h3>
                        
                        <p class="text-off text-base leading-relaxed mb-8 flex-1">Déficit structurel de l'offre vs demande exponentielle des data centers et de la transition énergétique.</p>
                        
                        <div class="mt-auto pt-6 flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Conviction</span>
                                <span class="text-[0.75rem] font-bold text-orange-600 uppercase tracking-wide">Moyenne</span>
                            </div>
                            <a href="/recherches/copper-electrification" class="inline-flex items-center gap-2 text-[0.7rem] uppercase tracking-widest font-bold text-text group-hover:text-blue-3 transition-colors">
                                Lire <span class="group-hover:translate-x-1 transition-transform">→</span>
                            </a>
                        </div>
                    </div>
                </article>

                <!-- Thesis Card 3: USD -->
                <article class="group relative flex flex-col bg-white border border-border hover:border-blue-3 transition-colors shadow-sm hover:shadow-md overflow-hidden">
                    <div class="absolute top-0 left-0 w-full h-1 bg-blue-3 scale-x-0 group-hover:scale-x-100 transition-transform origin-left z-10"></div>
                    
                    <div class="h-48 overflow-hidden border-b border-border relative">
                        <img src="https://images.unsplash.com/photo-1611974789855-9c2a0a7236a3?auto=format&fit=crop&w=800&q=80" alt="Global Markets USD" class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700" />
                        <div class="absolute inset-0 bg-gradient-to-t from-dark/50 to-transparent"></div>
                    </div>
                    
                    <div class="p-8 flex flex-col flex-1">
                        <div class="flex items-center justify-between mb-6 pb-6 border-b border-border/50">
                            <span class="text-[0.65rem] font-bold uppercase tracking-widest text-blue-3">FX / Macro</span>
                            <span class="text-[0.65rem] text-dim uppercase tracking-widest">Mars 2026</span>
                        </div>
                        
                        <h3 class="font-head text-3xl text-text mb-6 leading-tight group-hover:text-blue-3 transition-colors">USD : Taux Réels & Exceptionnalisme</h3>
                        
                        <p class="text-off text-base leading-relaxed mb-8 flex-1">Analyse de la persistance de la force du Dollar face aux flux de capitaux cherchant le rendement réel.</p>
                        
                        <div class="mt-auto pt-6 flex justify-between items-center">
                            <div class="flex flex-col">
                                <span class="text-[0.6rem] text-dim uppercase tracking-widest mb-1">Conviction</span>
                                <span class="text-[0.75rem] font-bold text-green-600 uppercase tracking-wide">Haute</span>
                            </div>
                            <a href="/recherches/usd-macro-dominance" class="inline-flex items-center gap-2 text-[0.7rem] uppercase tracking-widest font-bold text-text group-hover:text-blue-3 transition-colors">
                                Lire <span class="group-hover:translate-x-1 transition-transform">→</span>
                            </a>
                        </div>
                    </div>
                </article>
            </div>
        </div>

        <div class="container">
            <div class="section-rule mb-12">
                <h2 class="section-label">Nos Portefeuilles Modèles</h2>
                <div class="rule-line"></div>
            </div>

            {portfolios.length === 0 ? (
                <div class="py-20 text-center border border-dashed border-border">
                    <p class="text-dim">Aucun portfolio disponible pour le moment.</p>
                </div>
            ) : (
                <div class="flex flex-col gap-6">
                    {portfolios.map(async (portfolio) => {
                        const { Content } = await portfolio.render();
                        const isNegativeYtd = portfolio.data.stats.ytd.startsWith('-');
                        const isNegativeSharpe = portfolio.data.stats.sharpe.startsWith('-');
                        
                        return (
                            <details class="portfolio-card bg-white border border-border shadow-sm group/details">
                                <summary class="bg-dark text-white p-6 md:p-8 flex flex-col md:flex-row md:items-center justify-between gap-4 cursor-pointer hover:bg-dark-2 transition-colors select-none list-none relative">
                                    <!-- Left: Title and Risk -->
                                    <div class="flex flex-col gap-2">
                                        <div class="flex items-center gap-3">
                                            <span class={`px-2 py-0.5 text-[0.5rem] font-bold uppercase tracking-wider ${
                                                portfolio.data.riskLevel === 'High' ? 'bg-red-600' : 
                                                portfolio.data.riskLevel === 'Medium' ? 'bg-orange-500' : 
                                                'bg-blue-600'
                                            }`}>
                                                Risque {portfolio.data.riskLevel}
                                            </span>
                                            <span class="text-[0.55rem] font-mono text-dim uppercase tracking-widest italic">Actualisé : {portfolio.data.lastUpdated}</span>
                                        </div>
                                        <h2 class="font-head text-2xl md:text-3xl text-white m-0 leading-tight italic group-hover/details:text-blue-3 transition-colors">{portfolio.data.title}</h2>
                                    </div>
                                    
                                    <!-- Right: Mobile-friendly KPIs and Chevron -->
                                    <div class="flex items-center justify-between md:justify-end gap-6 md:gap-8 border-t md:border-t-0 border-white/10 pt-4 md:pt-0">
                                        <div class="flex items-center gap-6">
                                            <div class="flex flex-col">
                                                <span class="text-[0.5rem] text-dim uppercase tracking-widest font-mono mb-1">YTD</span>
                                                <span class={`text-lg md:text-xl font-sans font-bold leading-none ${isNegativeYtd ? 'text-red-400' : 'text-green-400'}`}>
                                                    {portfolio.data.stats.ytd}
                                                </span>
                                            </div>
                                            <div class="flex flex-col">
                                                <span class="text-[0.5rem] text-dim uppercase tracking-widest font-mono mb-1">Sharpe</span>
                                                <span class={`text-lg md:text-xl font-sans font-bold leading-none ${isNegativeSharpe ? 'text-red-400' : 'text-white'}`}>
                                                    {portfolio.data.stats.sharpe}
                                                </span>
                                            </div>
                                        </div>
                                        <div class="w-8 h-8 rounded-full border border-white/20 flex items-center justify-center text-white/50 group-hover/details:border-blue-3 group-hover/details:text-blue-3 transition-colors group-open/details:rotate-180 shrink-0">
                                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
                                        </div>
                                    </div>
                                </summary>
                                
                                <!-- Collapsible Content -->
                                <div class="p-6 md:p-10 border-t border-blue-3/30">
                                    <div class="mb-10 max-w-3xl">
                                        <p class="text-off text-base leading-relaxed font-light italic">{portfolio.data.description}</p>
                                    </div>

                                    <!-- Table Container -->
                                    <div class="mb-12 border border-border bg-white shadow-sm relative">
                                        <div class="bg-bg-2 text-text px-4 md:px-6 py-3 border-b border-border flex justify-between items-center">
                                            <h3 class="font-sans text-[0.55rem] md:text-[0.6rem] uppercase tracking-[0.2em] font-bold">Positions ({portfolio.data.positions.length})</h3>
                                            <span class="text-[0.55rem] text-dim font-mono">Volatilité Ann. : <span class="font-bold text-text">{portfolio.data.stats.volatility}</span></span>
                                        </div>
                                        <div class="overflow-x-auto scrollbar-hide">
                                            <table class="w-full text-left border-collapse min-w-[500px] md:min-w-[800px]">
                                                <thead>
                                                    <tr class="bg-white text-dim text-[0.5rem] md:text-[0.6rem] uppercase tracking-[0.1em] font-bold border-b border-border">
                                                        <th class="px-4 md:px-6 py-3 md:py-4 w-24">Actif</th>
                                                        <th class="px-4 md:px-6 py-3 md:py-4">Instrument</th>
                                                        <th class="px-4 md:px-6 py-3 md:py-4 w-32">Allocation</th>
                                                        <th class="px-4 md:px-6 py-3 md:py-4">Rationale Stratégique</th>
                                                    </tr>
                                                </thead>
                                                <tbody class="divide-y divide-border/30">
                                                    {portfolio.data.positions.map((pos) => (
                                                        <tr class="hover:bg-blue-d transition-colors group/row">
                                                            <td class="px-4 md:px-6 py-4 md:py-5 align-top">
                                                                <span class="text-[0.5rem] md:text-[0.6rem] text-blue-3 font-mono font-bold uppercase border border-blue-3/10 px-1.5 py-0.5 bg-blue-d whitespace-nowrap">{pos.type}</span>
                                                            </td>
                                                            <td class="px-4 md:px-6 py-4 md:py-5 align-top">
                                                                <div class="flex flex-col gap-1">
                                                                    <span class="font-sans text-sm md:text-base text-text font-bold group-hover/row:text-blue-3 transition-colors">{pos.asset}</span>
                                                                    <span class={`inline-block px-1.5 py-0.5 text-[0.45rem] md:text-[0.5rem] font-bold uppercase border w-max ${
                                                                        pos.conviction === 'High' ? 'border-blue-3/30 text-blue-700 bg-blue-50' : 
                                                                        pos.conviction === 'Medium' ? 'border-orange-500/30 text-orange-700 bg-orange-50' : 
                                                                        'border-border text-dim bg-bg-2'
                                                                    }`}>
                                                                        {pos.conviction}
                                                                    </span>
                                                                </div>
                                                            </td>
                                                            <td class="px-4 md:px-6 py-4 md:py-5 align-top">
                                                                <div class="flex items-center gap-2">
                                                                    <span class="font-sans text-sm md:text-base font-bold text-text">{pos.weight}</span>
                                                                    <div class="hidden md:block w-12 xl:w-20 h-1 bg-border rounded-none overflow-hidden">
                                                                        <div class="h-full bg-blue-3" style={`width: ${pos.weight}`}></div>
                                                                    </div>
                                                                </div>
                                                            </td>
                                                            <td class="px-4 md:px-6 py-4 md:py-5 align-top text-off text-[0.65rem] md:text-[0.8rem] italic font-light leading-relaxed max-w-[200px] md:max-w-sm font-sans">
                                                                {pos.thesis}
                                                            </td>
                                                        </tr>
                                                    ))}
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                    
                                    <!-- Analysis Content -->
                                    <div class="prose prose-sm md:prose-base max-w-none pt-8 border-t border-border prose-headings:font-head prose-headings:italic prose-headings:text-text prose-p:text-off prose-p:leading-relaxed prose-strong:text-text prose-strong:font-bold">
                                        <Content />
                                    </div>
                                </div>
                            </details>
                        );
                    })}
                </div>
            )}
        </div>
    </main>
</BaseLayout>

<style>
    details > summary::-webkit-details-marker {
        display: none;
    }
    
    details > summary {
        list-style: none;
    }
    
    table th {
        border-bottom: 2px solid var(--blue-3);
    }
    
    tr:last-child td {
        border-bottom: none;
    }
</style>

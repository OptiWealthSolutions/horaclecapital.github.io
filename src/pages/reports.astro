---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allRapports = await getCollection('rapports', ({ data }) => !data.draft);
const rapports = allRapports.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const featured = rapports[0];
const grid = rapports.slice(1);

function formatDateFull(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

function formatDateShort(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('fr-FR', {
    day: '2-digit', month: 'short', year: 'numeric',
  });
}

const fallbackImg = '/assets/img/banner.jpg';
const title = 'Rapports Macro | Horacle Capital';
const description = "Rapports macroéconomiques hebdomadaires d'Horacle Capital : banques centrales, cycles, géopolitique et marchés financiers.";
---

<BaseLayout {title} {description} activeNav="reports">
    <header class="page-header">
      <img src="/assets/img/banner.jpg" alt="" class="header-bg" aria-hidden="true" />
      <span>Publications</span>
      <h1>Rapports Macro</h1>
      <p>Analyses hebdomadaires de l'environnement macro-financier</p>
    </header>

      <!-- Article à la une -->
      {featured && (
        <div class="container pt-14 pb-0">
          <a href={`/reports/${featured.slug}`} class="flex flex-col lg:flex-row border border-[var(--border)] overflow-hidden mb-16 group">
            <div class="relative lg:w-[58%] overflow-hidden bg-[var(--bg-2)]" style="min-height:300px">
              <img
                src={featured.data.thumbnail || fallbackImg}
                alt={featured.data.title}
                class="absolute inset-0 w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700"
                onerror={`this.src='${fallbackImg}'`}
              />
            </div>
            <div class="lg:w-[42%] p-8 lg:p-12 flex flex-col justify-between bg-[var(--bg)]">
              <div>
                <div class="flex items-center gap-3 mb-6 flex-wrap">
                  <span style="font-family:var(--ff-body);font-size:0.6rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--blue-2);border:1px solid rgba(37,99,235,0.3);padding:3px 10px;background:rgba(37,99,235,0.05)">Rapport Hebdo</span>
                  <span style="font-family:var(--ff-body);font-size:0.7rem;color:var(--dim);letter-spacing:0.06em;text-transform:uppercase">{formatDateFull(featured.data.date)}</span>
                </div>
                <h2 class="font-head text-[var(--text)] leading-tight mb-5" style="font-size:clamp(1.5rem,3vw,2rem)">{featured.data.title}</h2>
                <p style="font-family:var(--ff-body);font-size:0.92rem;color:var(--off);line-height:1.7;margin-bottom:2rem">
                  {featured.data.description}
                </p>
              </div>
              <div class="btn-primary self-start">
                Lire le rapport
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              </div>
            </div>
          </a>
        </div>
      )}

      <!-- Grille des publications -->
      <div class="container pb-[120px]">
        <div class="section-rule mb-10">
          <span class="section-label">Toutes les publications</span>
          <div class="rule-line"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {grid.map((rapport) => (
            <a href={`/reports/${rapport.slug}`} class="group flex flex-col border border-[var(--border)] hover:border-[rgba(37,99,235,0.4)] transition-colors duration-300 overflow-hidden">
              <div class="relative overflow-hidden bg-[var(--bg-2)]" style="aspect-ratio:16/9">
                <img
                  src={rapport.data.thumbnail || fallbackImg}
                  alt={rapport.data.title}
                  class="w-full h-full object-cover group-hover:scale-[1.04] transition-transform duration-500"
                  onerror={`this.src='${fallbackImg}'`}
                />
              </div>
              <div class="p-6 flex flex-col flex-1">
                <div class="flex items-center gap-3 mb-3">
                  <span style="font-family:var(--ff-body);font-size:0.58rem;font-weight:600;letter-spacing:0.12em;text-transform:uppercase;color:var(--blue-2)">{rapport.data.category}</span>
                  <span style="font-family:var(--ff-body);font-size:0.68rem;color:var(--dim)">{formatDateShort(rapport.data.date)}</span>
                </div>
                <h3 class="font-head text-[var(--text)] leading-snug mb-3 flex-1" style="font-size:1.05rem">{rapport.data.title}</h3>
                <p style="font-family:var(--ff-body);font-size:0.82rem;color:var(--off);line-height:1.65;margin-bottom:1.25rem">{rapport.data.description}</p>
                <span
                  style="display:inline-flex;align-items:center;gap:6px;font-family:var(--ff-body);font-size:0.65rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;border-bottom:1px solid var(--border);padding-bottom:3px;transition:color 0.2s"
                  class="text-text group-hover:text-blue-2"
                >
                  Lire
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
</BaseLayout>

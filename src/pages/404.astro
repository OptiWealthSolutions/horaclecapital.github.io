---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Page Introuvable - Erreur 404';
const description = "La page que vous recherchez n'existe plus ou a été déplacée.";
---
<BaseLayout {title} {description}>
    <header class="hero min-h-[40vh] md:min-h-[80vh] border-b-0 justify-center">
      <!-- Background Image (Optionnel, on met une très faible opacité) -->
      <img src="/assets/img/banner.jpg" alt="" class="hero-bg opacity-5" aria-hidden="true" />

      <div class="hero-inner">
        <div class="hero-tag">Erreur 404</div>
        <h1 class="text-[clamp(3rem,8vw,6rem)]">
          PAGE<br>
          <span class="o">INTROUVABLE</span>
        </h1>
        <p class="hero-sub font-sans normal-case tracking-normal text-[1.15rem] max-w-[650px] mb-10 leading-relaxed">
          La ressource que vous recherchez n'est plus disponible ou a été déplacée. Revenez à l'accueil pour explorer nos rapports financiers et nos recherches quantitatives.
        </p>
        <div class="hero-actions justify-center">
          <a href="/" class="btn-primary">
            Retourner à l'accueil
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><path d="M3 7h8M7 3l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <!-- Numéro de fond géant 404 -->
      <div class="hero-num text-[clamp(8rem,20vw,15rem)] right-5 bottom-0 opacity-[0.03]" aria-hidden="true">404</div>
    </header>
</BaseLayout>
